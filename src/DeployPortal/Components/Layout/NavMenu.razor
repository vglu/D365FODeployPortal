@using System.Reflection

<MudNavMenu>
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">
        Home
    </MudNavLink>
    <MudNavLink Href="/packages" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Inventory2">
        Packages
    </MudNavLink>
    <MudNavLink Href="/environments" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Cloud">
        Environments
    </MudNavLink>
    <MudNavLink Href="/deploy" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.RocketLaunch">
        Deploy
    </MudNavLink>
    <MudNavLink Href="/deployments" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.History">
        History
    </MudNavLink>
    <MudNavLink Href="/settings" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Settings">
        Settings
    </MudNavLink>
</MudNavMenu>

<div style="position:absolute; bottom:0; left:0; right:0; padding:12px 16px; border-top:1px solid var(--mud-palette-lines-default);">
    <MudStack Spacing="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Rocket" Size="Size.Small" Color="Color.Primary" />
            <MudText Typo="Typo.caption" Style="font-weight:600">
                Deploy Portal <span style="opacity:0.7">v@(_version)</span>
            </MudText>
        </MudStack>
        <MudText Typo="Typo.caption" Style="opacity:0.6; font-size:0.7rem">
            by <strong>SIMS tech</strong>
        </MudText>
    </MudStack>
</div>

@code {
    private string _version = Assembly.GetExecutingAssembly()
        .GetCustomAttribute<AssemblyInformationalVersionAttribute>()?.InformationalVersion
        ?? Assembly.GetExecutingAssembly().GetName().Version?.ToString(3)
        ?? "1.0.0";
}
