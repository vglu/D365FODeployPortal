@page "/deployments/{Id:int}"
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.AspNetCore.Components.Web.Virtualization
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Deployment #@Id</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2" Spacing="2">
    <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack"
               OnClick="@(() => Nav.NavigateTo("/deployments"))">
        Back to History
    </MudButton>
    @if (_deployment != null && (_deployment.Status == DeploymentStatus.Queued || _deployment.Status == DeploymentStatus.Converting || _deployment.Status == DeploymentStatus.Deploying || _deployment.Status == DeploymentStatus.Merging))
    {
        <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Cancel"
                   OnClick="@CancelDeployment">
            Cancel deployment
        </MudButton>
    }
</MudStack>

@if (_deployment != null)
{
    @* W1.4 (EPIC-UI-OVERLAP-FIX): grid was previously a single
       MudItem md="6" leaving the right half empty — looked like the
       page hadn't finished loading. Now: info table on the left,
       summary card on the right (status + duration prominently),
       so both halves carry weight. On md and below they stack. *@
    <MudGrid Spacing="3">
        <MudItem xs="12" md="7">
            <MudPaper Class="pa-4 h-100" Elevation="2">
                <MudText Typo="Typo.h5" Class="mb-3">Deployment #@_deployment.Id</MudText>
                <MudSimpleTable Dense="true">
                    <tbody>
                        <tr><td><strong>Package</strong></td><td>@_deployment.Package.Name</td></tr>
                        <tr><td><strong>Environment</strong></td><td>@_deployment.Environment.Name (@_deployment.Environment.Url)</td></tr>
                        <tr>
                            <td><strong>Status</strong></td>
                            <td>
                                <MudChip T="string" Color="@GetStatusColor(_deployment.Status)">
                                    @_deployment.Status
                                </MudChip>
                            </td>
                        </tr>
                        <tr><td><strong>Queued</strong></td><td>@_deployment.QueuedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td></tr>
                        <tr><td><strong>Started</strong></td><td>@(_deployment.StartedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td></tr>
                        <tr><td><strong>Completed</strong></td><td>@(_deployment.CompletedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td></tr>
                        <tr>
                            <td><strong>Duration</strong></td>
                            <td>@GetDuration(_deployment)</td>
                        </tr>
                        @if (!string.IsNullOrEmpty(_deployment.DevOpsTaskUrl))
                        {
                            <tr>
                                <td><strong>DevOps Task</strong></td>
                                <td>
                                    <MudLink Href="@_deployment.DevOpsTaskUrl" Target="_blank" Color="Color.Info">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" />
                                            <span>@_deployment.DevOpsTaskUrl</span>
                                        </MudStack>
                                    </MudLink>
                                </td>
                            </tr>
                        }
                        @if (!string.IsNullOrEmpty(_deployment.ErrorMessage))
                        {
                            <tr><td><strong>Error</strong></td><td class="mud-error-text">@_deployment.ErrorMessage</td></tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="5">
            <MudPaper Class="pa-4 h-100" Elevation="2">
                <MudText Typo="Typo.h5" Class="mb-3">Summary</MudText>
                <MudStack Spacing="3">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@GetStatusIcon(_deployment.Status)"
                                 Color="@GetStatusColor(_deployment.Status)"
                                 Size="Size.Large" />
                        <div>
                            <MudText Typo="Typo.h6">@_deployment.Status</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Default">@GetStatusHint(_deployment.Status)</MudText>
                        </div>
                    </MudStack>

                    <MudDivider />

                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Default">Duration</MudText>
                        <MudText Typo="Typo.h6">@GetDuration(_deployment)</MudText>
                    </div>

                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Default">Log entries</MudText>
                        <MudText Typo="Typo.h6">@_logs.Count</MudText>
                    </div>

                    @if (_logs.Any(l => l.Level == "Error"))
                    {
                        <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">
                            @_logs.Count(l => l.Level == "Error") error(s) in log
                        </MudAlert>
                    }
                    else if (_logs.Any(l => l.Level == "Warning"))
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                            @_logs.Count(l => l.Level == "Warning") warning(s) in log
                        </MudAlert>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* W2.1 (EPIC-UI-OVERLAP-FIX): log pane is now virtualized via
       <Virtualize>. ItemSize=22 matches single-line monospace at
       0.85rem with 1px vertical padding (see .log-line in app.css).
       Long messages still wrap via white-space:pre-wrap and overflow
       below; Virtualize tolerates per-row variance.
       Auto-scroll: a JS helper scrolls _logPane to the bottom after
       each new log row, but only if the toggle is on AND the user
       hasn't manually scrolled away. *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-4 mb-2" Spacing="2">
        <MudText Typo="Typo.h5">Deployment Log</MudText>
        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">
            @_logs.Count entries
        </MudChip>
        <MudSpacer />
        <MudSwitch T="bool" @bind-Value="_autoScroll" Color="Color.Primary" Size="Size.Small">
            Auto-scroll
        </MudSwitch>
    </MudStack>
    @* Plain <div> instead of MudPaper because MudPaper does not
       expose its ElementReference; we need the ref for JS-driven
       auto-scroll. .code-surface already provides border + bg via
       --mud-palette-* tokens. *@
    <div class="code-surface pa-3" @ref="_logPaneRef"
         style="max-height: clamp(320px, calc(100vh - 480px), 720px); overflow-y: auto;">
        @if (!_logs.Any())
        {
            <div class="log-ts">No log entries yet. Waiting...</div>
        }
        else
        {
            <Virtualize Items="_logs" Context="log" ItemSize="22" OverscanCount="20">
                <div class="log-line @(log.Level == "Error" ? "log-error" : log.Level == "Warning" ? "log-warning" : "")">
                    <span class="log-ts">@log.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                    <span class="log-tag">[@log.Level]</span>
                    @log.Message
                </div>
            </Virtualize>
        }
    </div>
}
else
{
    <MudProgressCircular Indeterminate="true" />
}

@code {
    [Parameter] public int Id { get; set; }

    private Deployment? _deployment;
    private List<DeploymentLog> _logs = new();
    private HubConnection? _hubConnection;
    private bool _autoScroll = true;
    private ElementReference _logPaneRef;
    private bool _newLogPending;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        await ConnectToHub();
    }

    private async Task LoadData()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _deployment = await db.Deployments
            .Include(d => d.Package)
            .Include(d => d.Environment)
            .FirstOrDefaultAsync(d => d.Id == Id);

        _logs = await db.DeploymentLogs
            .Where(l => l.DeploymentId == Id)
            .OrderBy(l => l.Timestamp)
            .ToListAsync();
    }

    private async Task ConnectToHub()
    {
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/hubs/deploylog"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<string, string, string>("ReceiveLog", (time, level, message) =>
        {
            _logs.Add(new DeploymentLog
            {
                Timestamp = DateTime.TryParse(time, out var t) ? t : DateTime.UtcNow,
                Level = level,
                Message = message
            });
            // W2.1: flag a new log; OnAfterRenderAsync will pump the
            // JS auto-scroll AFTER Virtualize has laid out the new row.
            _newLogPending = true;
            InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<string>("StatusChanged", async (status) =>
        {
            await LoadData();
            await InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();
        await _hubConnection.InvokeAsync("JoinDeploymentGroup", Id);
    }

    private Color GetStatusColor(DeploymentStatus status) => status switch
    {
        DeploymentStatus.Success => Color.Success,
        DeploymentStatus.Failed => Color.Error,
        DeploymentStatus.Cancelled => Color.Warning,
        DeploymentStatus.Deploying or DeploymentStatus.Converting or DeploymentStatus.Merging => Color.Info,
        DeploymentStatus.Queued => Color.Default,
        _ => Color.Default
    };

    private string GetStatusIcon(DeploymentStatus status) => status switch
    {
        DeploymentStatus.Success => Icons.Material.Filled.CheckCircle,
        DeploymentStatus.Failed => Icons.Material.Filled.Error,
        DeploymentStatus.Cancelled => Icons.Material.Filled.Cancel,
        DeploymentStatus.Deploying => Icons.Material.Filled.RocketLaunch,
        DeploymentStatus.Converting => Icons.Material.Filled.Transform,
        DeploymentStatus.Merging => Icons.Material.Filled.MergeType,
        DeploymentStatus.Queued => Icons.Material.Filled.Schedule,
        _ => Icons.Material.Filled.HelpOutline
    };

    private string GetStatusHint(DeploymentStatus status) => status switch
    {
        DeploymentStatus.Success => "Completed without errors",
        DeploymentStatus.Failed => "Stopped due to error — check the log",
        DeploymentStatus.Cancelled => "Stopped by user",
        DeploymentStatus.Deploying => "PAC is pushing the package",
        DeploymentStatus.Converting => "LCS → Unified conversion",
        DeploymentStatus.Merging => "Combining LCS sources",
        DeploymentStatus.Queued => "Waiting for an available worker",
        _ => ""
    };

    private async Task CancelDeployment()
    {
        if (_deployment == null) return;
        var result = await DialogService.ShowMessageBox(
            "Cancel Deployment",
            $"Cancel deployment #{_deployment.Id}? It will not run (or will stop being retried after restart).",
            yesText: "Cancel deployment",
            cancelText: "Keep");
        if (result != true) return;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var d = await db.Deployments.FindAsync(_deployment.Id);
            if (d == null) { Snackbar.Add("Deployment not found.", Severity.Warning); return; }
            if (d.Status == DeploymentStatus.Success || d.Status == DeploymentStatus.Failed || d.Status == DeploymentStatus.Cancelled)
            {
                Snackbar.Add($"Deployment is already {d.Status}.", Severity.Info);
                await LoadData();
                StateHasChanged();
                return;
            }
            d.Status = DeploymentStatus.Cancelled;
            d.CompletedAt = DateTime.UtcNow;
            d.ErrorMessage = "Cancelled by user.";
            await db.SaveChangesAsync();
            Snackbar.Add($"Deployment #{_deployment.Id} cancelled.", Severity.Success);
            await LoadData();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to cancel: {ex.Message}", Severity.Error);
        }
    }

    private string GetDuration(Deployment d)
    {
        if (d.StartedAt == null) return "-";
        var end = d.CompletedAt ?? DateTime.UtcNow;
        var duration = end - d.StartedAt.Value;
        if (duration.TotalHours >= 1)
            return duration.ToString(@"h\:mm\:ss");
        return duration.ToString(@"mm\:ss");
    }

    // GetLogStyle removed in W1.4 — log levels now styled via .log-error /
    // .log-warning classes in app.css using --mud-palette-* tokens.

    // W2.1: pump auto-scroll after new logs land. We only force the
    // scroll when (a) the user has the toggle on AND (b) they were
    // already near the bottom — otherwise we respect their manual
    // scroll position.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_newLogPending) return;
        _newLogPending = false;
        if (!_autoScroll) return;
        try
        {
            var atBottom = await JS.InvokeAsync<bool>("deployPortalLog.isAtBottom", _logPaneRef, 64);
            if (atBottom)
            {
                await JS.InvokeVoidAsync("deployPortalLog.scrollToBottom", _logPaneRef);
            }
        }
        catch (JSDisconnectedException) { /* circuit closed during teardown — safe to ignore */ }
        catch (TaskCanceledException) { /* component disposed mid-call */ }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection != null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}
