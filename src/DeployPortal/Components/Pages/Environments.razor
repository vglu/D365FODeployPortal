@page "/environments"
@inject EnvironmentService EnvService
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Environments</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Environments</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Outlined" Color="Color.Warning"
               StartIcon="@Icons.Material.Filled.Key"
               OnClick="@(() => _spGuideDialogVisible = true)">
        SP Setup Guide
    </MudButton>
    <MudButton Variant="Variant.Outlined" Color="Color.Default"
               StartIcon="@Icons.Material.Filled.Download"
               OnClick="@ExportEnvironments" Disabled="@(_environments.Count == 0)">
        Export
    </MudButton>
    <MudButton Variant="Variant.Outlined" Color="Color.Default"
               StartIcon="@Icons.Material.Filled.Upload"
               OnClick="@(() => _importBackupDialogVisible = true)">
        Import backup
    </MudButton>
    <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
               StartIcon="@Icons.Material.Filled.ContentPaste"
               OnClick="@OpenImportDialog">
        Import from Script
    </MudButton>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="@OpenAddDialog">
        Add Environment
    </MudButton>
</MudStack>

<MudTable Items="@_environments" Dense="true" Hover="true" Elevation="2" Loading="@_loading"
          Filter="new Func<Models.Environment, bool>(EnvFilter)" FixedHeader="true"
          Breakpoint="Breakpoint.None">
    <ToolBarContent>
        <MudSpacer />
        <MudTextField @bind-Value="_searchText" Placeholder="Search..." Variant="Variant.Outlined"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" DebounceInterval="200" Margin="Margin.Dense"
                      Clearable="true" Style="max-width:280px" />
    </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="new Func<Models.Environment, object>(e => e.Name)" InitialDirection="SortDirection.Ascending">Name</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<Models.Environment, object>(e => e.Url)">URL</MudTableSortLabel></MudTh>
        <MudTh>Org Friendly Name</MudTh>
        <MudTh Style="width:90px">Auth</MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<Models.Environment, object>(e => e.TenantId)">Tenant ID</MudTableSortLabel></MudTh>
        <MudTh>App ID</MudTh>
        <MudTh>Secret</MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<Models.Environment, object>(e => e.IsActive)">Active</MudTableSortLabel></MudTh>
        <MudTh Style="width:80px">Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Name">@context.Name</MudTd>
        <MudTd DataLabel="URL">
            <span class="mud-text-secondary" style="font-size:0.85rem">@context.Url</span>
        </MudTd>
        <MudTd DataLabel="Org Friendly Name">
            @if (!string.IsNullOrWhiteSpace(context.OrganizationFriendlyName))
            { <span class="mud-text-secondary" style="font-size:0.85rem">@context.OrganizationFriendlyName</span> }
            else
            { <span class="mud-text-disabled">—</span> }
        </MudTd>
        <MudTd DataLabel="Auth">
            @if (context.HasServicePrincipal)
            { <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">SP</MudChip> }
            else
            { <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary">Interactive</MudChip> }
        </MudTd>
        <MudTd DataLabel="Tenant">@TruncateGuid(context.TenantId)</MudTd>
        <MudTd DataLabel="AppId">@TruncateGuid(context.ApplicationId)</MudTd>
        <MudTd DataLabel="Secret">@EnvService.GetMaskedSecret(context)</MudTd>
        <MudTd DataLabel="Active">
            <MudSwitch T="bool" Value="@context.IsActive" Color="Color.Success"
                       ValueChanged="@(async _ => await ToggleActive(context))" />
        </MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                           OnClick="@(() => OpenEditDialog(context))" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                           OnClick="@(() => DeleteEnvironment(context))" />
        </MudTd>
    </RowTemplate>
</MudTable>

@* ===== ADD/EDIT DIALOG ===== *@
<MudDialog @bind-Visible="_dialogVisible" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editingId.HasValue ? "Edit" : "Add") Environment</MudText>
    </TitleContent>
    <DialogContent>
        <MudSwitch @bind-Value="_formUseInteractive" Label="Extended: Interactive sign-in (no Service Principal)" Color="Color.Secondary" Class="mb-2" />
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3" Style="display:block">
            When on: only Name and URL required. At deploy time you open a link from the log and enter a code to sign in.
        </MudText>
        <MudTextField @bind-Value="_formName" Label="Name" Required="true" Class="mb-3" />
        <MudTextField @bind-Value="_formUrl" Label="URL (e.g. myenv.crm.dynamics.com)" Required="true" Class="mb-3" />
        @if (!_formUseInteractive)
        {
            <MudTextField @bind-Value="_formTenantId" Label="Tenant ID" Required="true" Class="mb-3" />
            <MudTextField @bind-Value="_formApplicationId" Label="Application (Client) ID" Required="true" Class="mb-3" />
            <MudTextField @bind-Value="_formClientSecret" Label="Client Secret" Required="@(!_editingId.HasValue)"
                          InputType="InputType.Password"
                          HelperText="@(_editingId.HasValue ? "Leave empty to keep current" : "")"
                          Class="mb-3" />
        }
        else
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                At deploy time you will see a link in the log. Open it in your browser and enter the code to sign in. Works locally and in Docker.
            </MudAlert>
        }
        <MudStack Row="true" AlignItems="AlignItems.End" Class="mb-3">
            <MudTextField @bind-Value="_formOrganizationFriendlyName" Label="Organization Friendly Name (optional)"
                          HelperText="From 'pac auth who'. Used to verify correct environment before deploy when enabled in Settings."
                          Style="flex: 1;" />
            @if (_editingId.HasValue)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small" Class="ms-2"
                           OnClick="@PullFriendlyName" Disabled="@_pullFriendlyNameLoading"
                           StartIcon="@Icons.Material.Filled.Refresh">
                    @(_pullFriendlyNameLoading ? "Pulling..." : "Pull Friendly Name")
                </MudButton>
            }
        </MudStack>
        @if (_editingId.HasValue)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
                Pull Friendly Name: fetches from current environment via pac auth who (Service Principal required).
            </MudText>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@CloseDialog">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@SaveEnvironment">Save</MudButton>
    </DialogActions>
</MudDialog>

@* ===== IMPORT DIALOG ===== *@
<MudDialog @bind-Visible="_importDialogVisible" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.ContentPaste" Color="Color.Secondary" />
            <MudText Typo="Typo.h6">Import from Script Output</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (!_importParsed)
        {
            <MudText Typo="Typo.body2" Class="mb-3">
                Paste the output of <code>Setup-ServicePrincipal.ps1</code> or the contents of
                <code>ServicePrincipal_*.txt</code> file below. The parser will extract credentials and environment URLs.
            </MudText>

            <MudTextField @bind-Value="_importText" Label="Paste script output here"
                          Variant="Variant.Outlined" Lines="10"
                          Placeholder="Application (Client) ID:  xxxxxxxx-xxxx-...&#10;Directory (Tenant) ID:    xxxxxxxx-xxxx-...&#10;Client Secret:            xxxxxxxxxx...&#10;Environments (OK):        env1.crm.dynamics.com, env2.crm.dynamics.com"
                          Class="mb-3" Style="font-family:monospace; font-size:0.85rem" />

            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudFileUpload T="IBrowserFile" FilesChanged="@OnImportFileSelected" Accept=".txt,.log,.md">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.FileOpen">
                            Load from file
                        </MudButton>
                    </ActivatorContent>
                </MudFileUpload>
                <MudSpacer />
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="@ParseImportData"
                           Disabled="@string.IsNullOrWhiteSpace(_importText)"
                           StartIcon="@Icons.Material.Filled.AutoFixHigh">
                    Parse
                </MudButton>
            </MudStack>
        }
        else if (_parsedData != null)
        {
            @* ===== PARSED DATA PREVIEW ===== *@
            <MudText Typo="Typo.subtitle1" Class="mb-3" Color="Color.Success">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Class="mr-1" />
                Data parsed successfully
            </MudText>

            <MudPaper Class="pa-3 mb-3" Elevation="0" Style="background:var(--mud-palette-background-gray)">
                <MudSimpleTable Dense="true" Hover="false" Elevation="0" Style="background:transparent">
                    <tbody>
                        @if (!string.IsNullOrEmpty(_parsedData.ServicePrincipalName))
                        {
                            <tr><td style="width:180px"><strong>Service Principal</strong></td><td>@_parsedData.ServicePrincipalName</td></tr>
                        }
                        <tr>
                            <td><strong>Application ID</strong></td>
                            <td>
                                @if (!string.IsNullOrEmpty(_parsedData.ApplicationId))
                                {
                                    <code>@_parsedData.ApplicationId</code>
                                }
                                else
                                {
                                    <MudText Color="Color.Error">Not found</MudText>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Tenant ID</strong></td>
                            <td>
                                @if (!string.IsNullOrEmpty(_parsedData.TenantId))
                                {
                                    <code>@_parsedData.TenantId</code>
                                }
                                else
                                {
                                    <MudText Color="Color.Error">Not found</MudText>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Client Secret</strong></td>
                            <td>
                                @if (_parsedData.HasSecret)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">Found</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">Not found / masked</MudChip>
                                }
                            </td>
                        </tr>
                        @if (!string.IsNullOrEmpty(_parsedData.SecretExpiry))
                        {
                            <tr><td><strong>Secret Expiry</strong></td><td>@_parsedData.SecretExpiry</td></tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </MudPaper>

            @if (_parsedData.HasEnvironments)
            {
                <MudText Typo="Typo.subtitle2" Class="mb-2">
                    Environments (@_parsedData.Environments.Count found) — select which to create or update:
                </MudText>

                <MudPaper Class="pa-2 mb-3" Elevation="0" Style="background:var(--mud-palette-background-gray); max-height:250px; overflow-y:auto;">
                    @foreach (var env in _parsedData.Environments)
                    {
                        var existingEnv = _environments.FirstOrDefault(e => e.Url.Equals(env, StringComparison.OrdinalIgnoreCase));
                        var existing = existingEnv != null;
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-1">
                            @if (existing)
                            {
                                <MudCheckBox T="bool" Value="@_selectedUpdateEnvs.Contains(env)"
                                             ValueChanged="@(v => ToggleImportEnvUpdate(env, v))"
                                             Dense="true" Color="Color.Secondary" />
                                <MudText Typo="Typo.body2">@env</MudText>
                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Text">exists</MudChip>
                                @if (_selectedUpdateEnvs.Contains(env))
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Text">update credentials</MudChip>
                                }
                            }
                            else
                            {
                                <MudCheckBox T="bool" Value="@_selectedImportEnvs.Contains(env)"
                                             ValueChanged="@(v => ToggleImportEnv(env, v))"
                                             Dense="true" Color="Color.Primary" />
                                <MudText Typo="Typo.body2">@env</MudText>
                            }
                        </MudStack>
                    }
                </MudPaper>

                <MudStack Row="true" Spacing="2" Class="mb-2">
                    <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@SelectAllImportEnvs">Select all new</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@SelectAllImportEnvsUpdate">Select all existing (update)</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@DeselectAllImportEnvs">Deselect all</MudButton>
                </MudStack>
            }
            else
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                    No environment URLs detected. You can enter one manually below.
                </MudAlert>
                <MudTextField @bind-Value="_importManualUrl" Label="Environment URL"
                              Placeholder="myenv.crm.dynamics.com" Variant="Variant.Outlined"
                              Class="mb-3" />
            }

            @if (!_parsedData.HasSecret)
            {
                <MudTextField @bind-Value="_importManualSecret" Label="Client Secret (enter manually)"
                              InputType="InputType.Password" Variant="Variant.Outlined"
                              HelperText="Secret was not found in the pasted text. Enter it manually."
                              Class="mb-3" />
            }

            @if (_importCreating)
            {
                <MudProgressLinear Color="Color.Primary" Class="mt-3 mb-2" Indeterminate="@(_importProgressTotal == 0)"
                                   Value="@(_importProgressTotal > 0 ? 100.0 * _importProgressCurrent / _importProgressTotal : 0)" />
                <MudText Typo="Typo.body2" Class="mb-2">@_importProgressMessage</MudText>
            }
        }
    </DialogContent>
    <DialogActions>
        @if (_importParsed)
        {
            <MudButton OnClick="@(() => { _importParsed = false; })">Back</MudButton>
        }
        <MudButton OnClick="@CloseImportDialog">Cancel</MudButton>
        @if (_importParsed && _parsedData != null && _parsedData.HasCredentials)
        {
            var hasCreate = _selectedImportEnvs.Count > 0 || !string.IsNullOrWhiteSpace(_importManualUrl);
            var hasUpdate = _selectedUpdateEnvs.Count > 0;
            var canApply = hasCreate || hasUpdate;
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@CreateFromImport"
                       Disabled="@(_importCreating || !canApply)"
                       StartIcon="@Icons.Material.Filled.Add">
                @if (_importCreating)
                {
                    @("Applying...")
                }
                else if (hasCreate && hasUpdate)
                {
                    var createCount = _selectedImportEnvs.Count + (string.IsNullOrWhiteSpace(_importManualUrl) ? 0 : 1);
                    @($"Create {createCount}, Update {_selectedUpdateEnvs.Count}")
                }
                else if (hasCreate)
                {
                    var createCount = _selectedImportEnvs.Count + (string.IsNullOrWhiteSpace(_importManualUrl) ? 0 : 1);
                    @(createCount == 1 ? "Create 1 environment" : $"Create {createCount} environment(s)")
                }
                else if (hasUpdate)
                {
                    @(_selectedUpdateEnvs.Count == 1 ? "Update 1 environment" : $"Update {_selectedUpdateEnvs.Count} environment(s)")
                }
                else
                {
                    @("Create / Update")
                }
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@* ===== IMPORT BACKUP (JSON) DIALOG ===== *@
<MudDialog @bind-Visible="_importBackupDialogVisible" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Upload" Color="Color.Secondary" />
            <MudText Typo="Typo.h6">Import from backup</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-3">
            Upload a previously exported environments JSON file. All environments from the file will be added (same machine backup restore).
        </MudText>
        <MudFileUpload T="IReadOnlyList<IBrowserFile>" FilesChanged="@OnImportBackupFileSelected" Accept=".json" MaximumFileCount="1">
            <ActivatorContent>
                <MudButton Variant="Variant.Outlined" FullWidth="true" StartIcon="@Icons.Material.Filled.FolderOpen">
                    Select JSON file
                </MudButton>
            </ActivatorContent>
        </MudFileUpload>
        @if (!string.IsNullOrEmpty(_importBackupError))
        {
            <MudAlert Severity="Severity.Error" Class="mt-3" Dense="true">@_importBackupError</MudAlert>
        }
        @if (_importBackupCount > 0)
        {
            <MudAlert Severity="Severity.Success" Class="mt-3" Dense="true">@_importBackupCount environment(s) will be imported.</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => { _importBackupDialogVisible = false; _importBackupError = null; _importBackupCount = 0; })">Close</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@DoImportBackup"
                   Disabled="@(_importBackupData == null)" StartIcon="@Icons.Material.Filled.Upload">
            Import
        </MudButton>
    </DialogActions>
</MudDialog>

@* ===== SP SETUP GUIDE DIALOG ===== *@
<MudDialog @bind-Visible="_spGuideDialogVisible" Options="new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true, CloseOnEscapeKey = true }">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Key" Color="Color.Warning" />
            <MudText Typo="Typo.h6">Service Principal Setup Guide</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
            @* ===== TAB 1: MANUAL INSTRUCTIONS ===== *@
            <MudTabPanel Text="Manual Instructions" Icon="@Icons.Material.Filled.MenuBook">
                <MudText Typo="Typo.body2" Class="mb-3">
                    Follow these steps to create a Service Principal for automated D365FO package deployment via PAC CLI.
                    The SP enables non-interactive authentication for deploying packages to Power Platform environments.
                </MudText>

                <MudTimeline TimelineAlign="TimelineAlign.Start" TimelinePosition="TimelinePosition.Start">
                    @* Step 1 *@
                    <MudTimelineItem Color="Color.Primary" Size="Size.Small">
                        <ItemContent>
                            <MudText Typo="Typo.subtitle2" Color="Color.Primary">Part 1: Register App in Entra ID</MudText>
                            <MudText Typo="Typo.body2">
                                Go to <strong>Azure Portal</strong> &rarr; <strong>Microsoft Entra ID</strong> &rarr; <strong>App registrations</strong> &rarr; <strong>New registration</strong>
                            </MudText>
                            <MudList T="string" Dense="true" Class="ml-n2">
                                <MudListItem Icon="@Icons.Material.Filled.ChevronRight" IconSize="Size.Small"><strong>Name:</strong> <code>PAC-Deploy-Automation</code></MudListItem>
                                <MudListItem Icon="@Icons.Material.Filled.ChevronRight" IconSize="Size.Small"><strong>Account types:</strong> Single tenant</MudListItem>
                                <MudListItem Icon="@Icons.Material.Filled.ChevronRight" IconSize="Size.Small"><strong>Redirect URI:</strong> leave empty</MudListItem>
                            </MudList>
                            <MudText Typo="Typo.body2">Note down the <strong>Application (Client) ID</strong> and <strong>Directory (Tenant) ID</strong>.</MudText>
                        </ItemContent>
                    </MudTimelineItem>

                    @* Step 2 *@
                    <MudTimelineItem Color="Color.Primary" Size="Size.Small">
                        <ItemContent>
                            <MudText Typo="Typo.subtitle2" Color="Color.Primary">Part 2: Create Client Secret</MudText>
                            <MudText Typo="Typo.body2">
                                On the app page &rarr; <strong>Certificates &amp; secrets</strong> &rarr; <strong>New client secret</strong>
                            </MudText>
                            <MudAlert Severity="Severity.Warning" Dense="true" Variant="Variant.Text" Class="mt-1">
                                Copy the <strong>Value</strong> immediately — it is only shown once!
                            </MudAlert>
                        </ItemContent>
                    </MudTimelineItem>

                    @* Step 3 *@
                    <MudTimelineItem Color="Color.Primary" Size="Size.Small">
                        <ItemContent>
                            <MudText Typo="Typo.subtitle2" Color="Color.Primary">Part 3: Assign API Permissions</MudText>
                            <MudText Typo="Typo.body2">
                                <strong>API permissions</strong> &rarr; <strong>Add a permission</strong> &rarr; <strong>APIs my organization uses</strong> &rarr; search <strong>Dataverse</strong>
                            </MudText>
                            <MudList T="string" Dense="true" Class="ml-n2">
                                <MudListItem Icon="@Icons.Material.Filled.ChevronRight" IconSize="Size.Small">Select <strong>Delegated permissions</strong> &rarr; <strong>user_impersonation</strong></MudListItem>
                                <MudListItem Icon="@Icons.Material.Filled.ChevronRight" IconSize="Size.Small">Click <strong>Grant admin consent</strong> for your tenant</MudListItem>
                            </MudList>
                        </ItemContent>
                    </MudTimelineItem>

                    @* Step 4 *@
                    <MudTimelineItem Color="Color.Primary" Size="Size.Small">
                        <ItemContent>
                            <MudText Typo="Typo.subtitle2" Color="Color.Primary">Part 4: Add Application User in each target environment (required)</MudText>
                            <MudAlert Severity="Severity.Warning" Dense="true" Variant="Variant.Text" Class="mt-1 mb-2">
                                After creating the Service Principal (Parts 1–3), you must add it as an <strong>Application User</strong> in <strong>each</strong> target environment. Otherwise <code>pac auth create</code> will report &quot;The user is not a member of the organization&quot; / Forbidden.
                            </MudAlert>
                            <MudText Typo="Typo.body2">For <strong>each target environment</strong> where you will deploy:</MudText>
                            <MudList T="string" Dense="true" Class="ml-n2">
                                <MudListItem Icon="@Icons.Material.Filled.ChevronRight" IconSize="Size.Small"><a href="https://admin.powerplatform.microsoft.com" target="_blank" rel="noopener">Power Platform Admin Center</a> &rarr; <strong>Environments</strong> &rarr; select the environment</MudListItem>
                                <MudListItem Icon="@Icons.Material.Filled.ChevronRight" IconSize="Size.Small"><strong>Settings</strong> &rarr; <strong>Users + permissions</strong> &rarr; <strong>Application users</strong></MudListItem>
                                <MudListItem Icon="@Icons.Material.Filled.ChevronRight" IconSize="Size.Small"><strong>+ New app user</strong> &rarr; <strong>+ Add an app</strong> &rarr; select your app (e.g. <code>PAC-Deploy-Automation</code> by Application ID)</MudListItem>
                                <MudListItem Icon="@Icons.Material.Filled.ChevronRight" IconSize="Size.Small">Choose <strong>Business unit</strong>, assign role <strong>System Administrator</strong> (or equivalent for deploy), then <strong>Save</strong></MudListItem>
                            </MudList>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Repeat for every environment that will use this Service Principal. One SP can be added to multiple environments.</MudText>
                        </ItemContent>
                    </MudTimelineItem>

                    @* Step 5 *@
                    <MudTimelineItem Color="Color.Success" Size="Size.Small">
                        <ItemContent>
                            <MudText Typo="Typo.subtitle2" Color="Color.Success">Part 5: Enter Credentials Here</MudText>
                            <MudText Typo="Typo.body2">
                                Use <strong>Add Environment</strong> or <strong>Import from Script</strong> button on this page to register your environments with the credentials.
                            </MudText>
                        </ItemContent>
                    </MudTimelineItem>
                </MudTimeline>

                <MudDivider Class="my-3" />
                <MudText Typo="Typo.subtitle2" Class="mb-2">Verification command (use <code>--name</code> for an isolated profile; required if running parallel deploys):</MudText>
                <MudPaper Class="pa-3" Elevation="0" Style="background:var(--mud-palette-background-gray); font-family:monospace; font-size:0.85rem; white-space:pre-wrap; overflow-x:auto">pac auth create --name "Deploy_MyEnv" --applicationId "&lt;APP_ID&gt;" --clientSecret "&lt;SECRET&gt;" --tenant "&lt;TENANT_ID&gt;" --environment "&lt;ENV_URL&gt;" --accept-cleartext-caching
pac auth who</MudPaper>
            </MudTabPanel>

            @* ===== TAB 2: AUTOMATION SCRIPT ===== *@
            <MudTabPanel Text="Automation Script" Icon="@Icons.Material.Filled.Terminal">
                <MudText Typo="Typo.body2" Class="mb-3">
                    This PowerShell script automates all steps above. It requires the following modules:
                    <code>Az.Accounts</code>, <code>Az.Resources</code>, <code>Microsoft.PowerApps.Administration.PowerShell</code>
                </MudText>

                <MudAlert Severity="Severity.Info" Dense="true" Variant="Variant.Outlined" Class="mb-3">
                    <strong>Prerequisites:</strong> Global Administrator or Application Administrator in Entra ID, System Administrator in Power Platform environments.
                </MudAlert>

                <MudText Typo="Typo.subtitle2" Class="mb-2">Usage examples:</MudText>
                <MudPaper Class="pa-3 mb-3" Elevation="0" Style="background:var(--mud-palette-background-gray); font-family:monospace; font-size:0.82rem; white-space:pre-wrap; overflow-x:auto"># Full setup — creates SP and registers in specified environments
.\Setup-ServicePrincipal.ps1 -Environments "env1.crm.dynamics.com","env2.crm.dynamics.com"

# Add a new environment to an existing SP
.\Setup-ServicePrincipal.ps1 -AddEnvironment "new-env.crm.dynamics.com"

# Add multiple environments at once
.\Setup-ServicePrincipal.ps1 -AddEnvironment "env-a.crm.dynamics.com","env-b.crm.dynamics.com"</MudPaper>

                <MudText Typo="Typo.subtitle2" Class="mb-2">Full script:</MudText>
                <MudPaper Class="pa-3" Elevation="0" Style="background:var(--mud-palette-background-gray); font-family:monospace; font-size:0.78rem; white-space:pre-wrap; overflow-x:auto; max-height:400px; overflow-y:auto">@_setupScript</MudPaper>

                <MudStack Row="true" Class="mt-3" Spacing="2">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.ContentCopy"
                               OnClick="@CopyScriptToClipboard">
                        Copy Script
                    </MudButton>
                    <MudText Typo="Typo.caption" Class="align-self-center" Color="Color.Tertiary">
                        Save as <code>Setup-ServicePrincipal.ps1</code> and run in PowerShell
                    </MudText>
                </MudStack>
            </MudTabPanel>
        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _spGuideDialogVisible = false)">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<Models.Environment> _environments = new();
    private bool _loading = true;
    private string _searchText = "";

    // Add/Edit form
    private bool _dialogVisible;
    private int? _editingId;
    private bool _formUseInteractive;
    private string _formName = "";
    private string _formUrl = "";
    private string _formTenantId = "";
    private string _formApplicationId = "";
    private string _formClientSecret = "";
    private string _formOrganizationFriendlyName = "";
    private bool _pullFriendlyNameLoading;

    // SP Setup Guide
    private bool _spGuideDialogVisible;

    // Import
    private bool _importDialogVisible;
    private string _importText = "";
    private bool _importParsed;
    private CredentialParser.ParsedCredentials? _parsedData;
    private HashSet<string> _selectedImportEnvs = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _selectedUpdateEnvs = new(StringComparer.OrdinalIgnoreCase);
    private string _importManualSecret = "";
    private string _importManualUrl = "";
    private bool _importCreating;
    private string _importProgressMessage = "";
    private int _importProgressCurrent;
    private int _importProgressTotal;

    // Import backup (JSON)
    private bool _importBackupDialogVisible;
    private List<DeployPortal.Models.Api.EnvironmentExportDto>? _importBackupData;
    private string? _importBackupError;
    private int _importBackupCount;

    // ===== Lifecycle =====
    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        _environments = await EnvService.GetAllAsync();
        _loading = false;
    }

    private bool EnvFilter(Models.Environment e)
    {
        if (string.IsNullOrWhiteSpace(_searchText)) return true;
        return e.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || e.Url.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || (e.OrganizationFriendlyName != null && e.OrganizationFriendlyName.Contains(_searchText, StringComparison.OrdinalIgnoreCase))
            || e.TenantId.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || e.ApplicationId.Contains(_searchText, StringComparison.OrdinalIgnoreCase);
    }

    // ===== Add/Edit =====
    private void OpenAddDialog()
    {
        _editingId = null;
        _formUseInteractive = false;
        _formName = _formUrl = _formTenantId = _formApplicationId = _formClientSecret = _formOrganizationFriendlyName = "";
        _dialogVisible = true;
    }

    private void OpenEditDialog(Models.Environment env)
    {
        _editingId = env.Id;
        _formUseInteractive = !env.HasServicePrincipal;
        _formName = env.Name;
        _formUrl = env.Url;
        _formTenantId = env.TenantId;
        _formApplicationId = env.ApplicationId;
        _formClientSecret = "";
        _formOrganizationFriendlyName = env.OrganizationFriendlyName ?? "";
        _dialogVisible = true;
    }

    private void CloseDialog() => _dialogVisible = false;

    private async Task SaveEnvironment()
    {
        if (string.IsNullOrWhiteSpace(_formName) || string.IsNullOrWhiteSpace(_formUrl))
        {
            Snackbar.Add("Name and URL are required.", Severity.Warning);
            return;
        }
        var useSp = !_formUseInteractive;
        if (useSp && string.IsNullOrWhiteSpace(_formApplicationId))
        {
            Snackbar.Add("Application ID is required when not using interactive sign-in.", Severity.Warning);
            return;
        }
        if (useSp && !_editingId.HasValue && string.IsNullOrWhiteSpace(_formClientSecret))
        {
            Snackbar.Add("Client Secret is required when not using interactive sign-in.", Severity.Warning);
            return;
        }
        try
        {
            var tenantId = useSp ? _formTenantId : "";
            var applicationId = useSp ? _formApplicationId : "";
            var clientSecret = useSp ? _formClientSecret : "";

            if (_editingId.HasValue)
            {
                await EnvService.UpdateAsync(_editingId.Value, _formName, _formUrl, tenantId, applicationId,
                    string.IsNullOrEmpty(clientSecret) ? null : clientSecret, _formOrganizationFriendlyName);
                Snackbar.Add("Environment updated.", Severity.Success);
            }
            else
            {
                await EnvService.CreateAsync(_formName, _formUrl, tenantId, applicationId, clientSecret);
                Snackbar.Add("Environment added.", Severity.Success);
            }
            _dialogVisible = false;
            await LoadData();
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ExceptionHelper.GetDisplayMessage(ex)}", Severity.Error); }
    }

    private async Task PullFriendlyName()
    {
        if (!_editingId.HasValue) return;
        _pullFriendlyNameLoading = true;
        StateHasChanged();
        try
        {
            await EnvService.RefreshOrganizationFriendlyNameAsync(_editingId.Value);
            var env = await EnvService.GetByIdAsync(_editingId.Value);
            _formOrganizationFriendlyName = env?.OrganizationFriendlyName ?? "";
            Snackbar.Add("Friendly Name updated from current environment.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Pull Friendly Name failed: {ExceptionHelper.GetDisplayMessage(ex)}", Severity.Error);
        }
        finally
        {
            _pullFriendlyNameLoading = false;
            StateHasChanged();
        }
    }

    // ===== Export / Import backup =====
    private async Task ExportEnvironments()
    {
        try
        {
            var count = _environments.Count;
            var url = Nav.ToAbsoluteUri("/api/environments/export").ToString();
            await JS.InvokeVoidAsync("open", url, "_blank");
            Snackbar.Add($"Export started ({count} environment(s)).", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"Export failed: {ExceptionHelper.GetDisplayMessage(ex)}", Severity.Error); }
    }

    private async Task OnImportBackupFileSelected(IReadOnlyList<IBrowserFile> files)
    {
        _importBackupError = null;
        _importBackupData = null;
        _importBackupCount = 0;
        if (files == null || files.Count == 0) { StateHasChanged(); return; }
        var file = files[0];
        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 512 * 1024);
            using var reader = new StreamReader(stream);
            var json = await reader.ReadToEndAsync();
            _importBackupData = System.Text.Json.JsonSerializer.Deserialize<List<DeployPortal.Models.Api.EnvironmentExportDto>>(json);
            _importBackupCount = _importBackupData?.Count ?? 0;
            if (_importBackupCount == 0) _importBackupError = "No valid environments in file.";
        }
        catch (Exception ex) { _importBackupError = ExceptionHelper.GetDisplayMessage(ex); }
        StateHasChanged();
    }

    private async Task DoImportBackup()
    {
        if (_importBackupData == null || _importBackupData.Count == 0) return;
        try
        {
            var created = await EnvService.ImportFromExportAsync(_importBackupData);
            Snackbar.Add($"{created} environment(s) imported.", Severity.Success);
            _importBackupDialogVisible = false;
            _importBackupData = null;
            _importBackupCount = 0;
            await LoadData();
        }
        catch (Exception ex) { _importBackupError = ExceptionHelper.GetDisplayMessage(ex); }
    }

    // ===== Import =====
    private void OpenImportDialog()
    {
        _importText = "";
        _importParsed = false;
        _parsedData = null;
        _selectedImportEnvs.Clear();
        _selectedUpdateEnvs.Clear();
        _importManualSecret = "";
        _importManualUrl = "";
        _importCreating = false;
        _importDialogVisible = true;
    }

    private void CloseImportDialog()
    {
        _importDialogVisible = false;
    }

    private async Task OnImportFileSelected(IBrowserFile file)
    {
        if (file == null) return;
        try
        {
            using var reader = new StreamReader(file.OpenReadStream(maxAllowedSize: 1024 * 1024));
            _importText = await reader.ReadToEndAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to read file: {ExceptionHelper.GetDisplayMessage(ex)}", Severity.Error);
        }
    }

    private void ParseImportData()
    {
        _parsedData = CredentialParser.Parse(_importText);
        _importParsed = true;

        // Pre-select environments that don't already exist (do not pre-select existing for update)
        _selectedImportEnvs.Clear();
        _selectedUpdateEnvs.Clear();
        if (_parsedData.HasEnvironments)
        {
            foreach (var env in _parsedData.Environments)
            {
                if (!_environments.Any(e => e.Url.Equals(env, StringComparison.OrdinalIgnoreCase)))
                    _selectedImportEnvs.Add(env);
            }
        }
    }

    private void ToggleImportEnv(string url, bool selected)
    {
        if (selected) _selectedImportEnvs.Add(url);
        else _selectedImportEnvs.Remove(url);
    }

    private void SelectAllImportEnvs()
    {
        if (_parsedData == null) return;
        foreach (var env in _parsedData.Environments)
        {
            if (!_environments.Any(e => e.Url.Equals(env, StringComparison.OrdinalIgnoreCase)))
                _selectedImportEnvs.Add(env);
        }
    }

    private void ToggleImportEnvUpdate(string url, bool selected)
    {
        if (selected) _selectedUpdateEnvs.Add(url);
        else _selectedUpdateEnvs.Remove(url);
    }

    private void SelectAllImportEnvsUpdate()
    {
        if (_parsedData == null) return;
        foreach (var env in _parsedData.Environments)
        {
            if (_environments.Any(e => e.Url.Equals(env, StringComparison.OrdinalIgnoreCase)))
                _selectedUpdateEnvs.Add(env);
        }
    }

    private void DeselectAllImportEnvs()
    {
        _selectedImportEnvs.Clear();
        _selectedUpdateEnvs.Clear();
    }

    private async Task CreateFromImport()
    {
        if (_parsedData == null || !_parsedData.HasCredentials) return;

        var secret = _parsedData.HasSecret ? _parsedData.ClientSecret! : _importManualSecret;
        if (string.IsNullOrWhiteSpace(secret))
        {
            Snackbar.Add("Client Secret is required. Enter it manually.", Severity.Warning);
            return;
        }

        var urlsToCreate = _selectedImportEnvs.ToList();
        if (urlsToCreate.Count == 0 && !string.IsNullOrWhiteSpace(_importManualUrl))
            urlsToCreate.Add(_importManualUrl.Trim());

        var urlsToUpdate = _selectedUpdateEnvs.ToList();

        if (urlsToCreate.Count == 0 && urlsToUpdate.Count == 0)
        {
            Snackbar.Add("Select at least one environment to create or update.", Severity.Warning);
            return;
        }

        _importCreating = true;
        _importProgressTotal = urlsToCreate.Count + urlsToUpdate.Count;
        _importProgressCurrent = 0;
        _importProgressMessage = _importProgressTotal > 0 ? "Starting..." : "";
        StateHasChanged();

        var created = 0;
        var updated = 0;
        var errors = 0;

        try
        {
            var idx = 0;
            foreach (var url in urlsToCreate)
            {
                try
                {
                    _importProgressMessage = $"Creating environment ({idx + 1}/{_importProgressTotal})...";
                    _importProgressCurrent = idx;
                    StateHasChanged();

                    var name = GenerateEnvName(url);
                    await EnvService.CreateAsync(name, url, _parsedData.TenantId!, _parsedData.ApplicationId!, secret);
                    created++;
                }
                catch (Exception ex)
                {
                    Snackbar.Add($"Failed to create '{url}': {ExceptionHelper.GetDisplayMessage(ex)}", Severity.Error);
                    errors++;
                }
                idx++;
            }

            var updateStartIdx = urlsToCreate.Count;
            idx = 0;
            foreach (var url in urlsToUpdate)
            {
                var env = _environments.FirstOrDefault(e => e.Url.Equals(url, StringComparison.OrdinalIgnoreCase));
                if (env == null) continue;
                try
                {
                    var envNum = updateStartIdx + idx + 1;
                    _importProgressMessage = $"Updating environment ({envNum}/{_importProgressTotal})...";
                    _importProgressCurrent = updateStartIdx + idx;
                    StateHasChanged();

                    await EnvService.UpdateAsync(env.Id, env.Name, url, _parsedData.TenantId!, _parsedData.ApplicationId!, secret);
                    updated++;
                }
                catch (Exception ex)
                {
                    Snackbar.Add($"Failed to update '{url}': {ExceptionHelper.GetDisplayMessage(ex)}", Severity.Error);
                    errors++;
                }
                idx++;
            }

            if (created > 0 || updated > 0)
            {
                var msg = new List<string>();
                if (created > 0) msg.Add($"{created} created");
                if (updated > 0) msg.Add($"{updated} updated");
                Snackbar.Add(string.Join(", ", msg) + " successfully!", Severity.Success);
                _importDialogVisible = false;
                await LoadData();
            }
        }
        finally
        {
            _importCreating = false;
            _importProgressMessage = "";
            _importProgressCurrent = 0;
            _importProgressTotal = 0;
        }
    }

    // ===== Other actions =====
    private async Task ToggleActive(Models.Environment env)
    {
        await EnvService.ToggleActiveAsync(env.Id);
        await LoadData();
    }

    private async Task DeleteEnvironment(Models.Environment env)
    {
        var result = await DialogService.ShowMessageBox("Delete Environment",
            $"Are you sure you want to delete '{env.Name}'?",
            yesText: "Delete", cancelText: "Cancel");
        if (result == true)
        {
            try
            {
                await EnvService.DeleteAsync(env.Id);
                Snackbar.Add("Environment deleted.", Severity.Info);
                await LoadData();
            }
            catch (InvalidOperationException ex)
            {
                Snackbar.Add(ex.Message, Severity.Warning);
            }
            catch (Exception ex)
            {
                Snackbar.Add(ExceptionHelper.GetDisplayMessage(ex), Severity.Error);
            }
        }
    }

    // ===== SP Setup Guide =====
    private const string _setupScript = @"#Requires -Modules Az.Accounts, Az.Resources, Microsoft.PowerApps.Administration.PowerShell

<#
.SYNOPSIS
    Creates a Service Principal for automated D365FO package deployment via PAC CLI.
.DESCRIPTION
    Two modes:
    - Full setup: creates SP + registers in all environments
    - Add environment: only registers existing SP in a new environment
.EXAMPLE
    .\Setup-ServicePrincipal.ps1 -Environments ""env1.crm.dynamics.com"",""env2.crm.dynamics.com""
.EXAMPLE
    .\Setup-ServicePrincipal.ps1 -AddEnvironment ""new-env.crm.dynamics.com""
#>

[CmdletBinding(DefaultParameterSetName = ""FullSetup"")]
param(
    [Parameter()]
    [string]$AppDisplayName = ""PAC-Deploy-Automation"",

    [Parameter(ParameterSetName = ""FullSetup"")]
    [int]$SecretExpirationMonths = 24,

    [Parameter(ParameterSetName = ""FullSetup"")]
    [string[]]$Environments = @(
        # Replace with your actual Power Platform environment URLs
        # ""your-env-01.crm.dynamics.com"",
        # ""your-env-02.crm.dynamics.com""
    ),

    [Parameter(Mandatory, ParameterSetName = ""AddEnv"")]
    [string[]]$AddEnvironment
)

$ErrorActionPreference = ""Stop""

function Log {
    param([string]$Message, [string]$Color = ""White"")
    Write-Host ""$(Get-Date -Format 'HH:mm:ss') - $Message"" -ForegroundColor $Color
}

$isAddEnvMode = $PSCmdlet.ParameterSetName -eq ""AddEnv""

if ($isAddEnvMode) {
    Log ""Mode: ADD ENVIRONMENT to existing SP '$AppDisplayName'"" ""Cyan""
} else {
    Log ""Mode: FULL SETUP of SP '$AppDisplayName'"" ""Cyan""
}

# PART 1: Authenticate
Log ""Signing in to Azure AD..."" ""Cyan""
Connect-AzAccount | Out-Null
$context = Get-AzContext
$tenantId = $context.Tenant.Id
Log ""Tenant: $tenantId"" ""Green""

# PART 2: App Registration
$existingApp = Get-AzADApplication -DisplayName $AppDisplayName -ErrorAction SilentlyContinue
if ($isAddEnvMode) {
    if (-not $existingApp) { Write-Error ""App not found. Run full setup first.""; exit 1 }
    $app = $existingApp
} else {
    if ($existingApp) { $app = $existingApp }
    else { $app = New-AzADApplication -DisplayName $AppDisplayName -SignInAudience ""AzureADMyOrg"" }
}
Log ""AppId: $($app.AppId)"" ""Green""

# PART 3: Service Principal
$sp = Get-AzADServicePrincipal -ApplicationId $app.AppId -ErrorAction SilentlyContinue
if (-not $sp) {
    if ($isAddEnvMode) { Write-Error ""SP not found. Run full setup first.""; exit 1 }
    $sp = New-AzADServicePrincipal -ApplicationId $app.AppId
    Log ""SP created."" ""Green""
}

# PART 4: Client Secret
$clientSecret = $null
if (-not $isAddEnvMode) {
    $endDate = (Get-Date).AddMonths($SecretExpirationMonths)
    $secret = New-AzADAppCredential -ApplicationId $app.AppId -EndDate $endDate
    $clientSecret = $secret.SecretText
    if (-not $clientSecret) { Write-Error ""Failed to get secret.""; exit 1 }
    Log ""Secret created. Expires: $($endDate.ToString('yyyy-MM-dd'))"" ""Green""
}

# PART 5: Dataverse API Permission
if (-not $isAddEnvMode) {
    $dataverseAppId = ""00000007-0000-0000-c000-000000000000""
    $userImpersonationId = ""78ce3f0f-a1ce-49c2-8cde-64b5c0896db4""
    $ra = New-Object Microsoft.Azure.PowerShell.Cmdlets.Resources.MSGraph.Models.ApiV10.MicrosoftGraphResourceAccess
    $ra.Id = $userImpersonationId; $ra.Type = ""Scope""
    $req = New-Object Microsoft.Azure.PowerShell.Cmdlets.Resources.MSGraph.Models.ApiV10.MicrosoftGraphRequiredResourceAccess
    $req.ResourceAppId = $dataverseAppId; $req.ResourceAccess = @($ra)
    try { Update-AzADApplication -ApplicationId $app.AppId -RequiredResourceAccess @($req) }
    catch { Log ""Add Dataverse permission manually."" ""Yellow"" }

    $consentLink = ""https://login.microsoftonline.com/$tenantId/adminconsent?client_id=$($app.AppId)""
    Log ""Grant admin consent: $consentLink"" ""Yellow""
    Start-Process $consentLink
    Read-Host ""Press Enter after granting consent""
}

# PART 6: Register in Power Platform
$targetEnvs = if ($isAddEnvMode) { $AddEnvironment } else { $Environments }
try { Add-PowerAppsAccount } catch { Log ""Connect to PPAC manually."" ""Red"" }

foreach ($envUrl in $targetEnvs) {
    try {
        New-PowerAppManagementApp -ApplicationId $app.AppId -ErrorAction Stop
        Log ""[OK] $envUrl"" ""Green""
    } catch {
        if ($_.Exception.Message -like ""*already exists*"") { Log ""[SKIP] $envUrl"" ""Yellow"" }
        else { Log ""[FAIL] $envUrl - $($_.Exception.Message)"" ""Red"" }
    }
}

# RESULT
Write-Host ""`nApplication (Client) ID: $($app.AppId)"" -ForegroundColor White
Write-Host ""Directory (Tenant) ID:   $tenantId"" -ForegroundColor White
if ($clientSecret) {
    Write-Host ""Client Secret:           $clientSecret"" -ForegroundColor White
    Write-Host ""IMPORTANT: Save the Client Secret - it will not be shown again!"" -ForegroundColor Red
}";

    private async Task CopyScriptToClipboard()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _setupScript);
            Snackbar.Add("Script copied to clipboard!", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Failed to copy. Please select and copy manually.", Severity.Warning);
        }
    }

    // ===== Helpers =====
    private static string TruncateGuid(string guid)
    {
        if (string.IsNullOrEmpty(guid) || guid.Length <= 13) return guid;
        return guid[..8] + "...";
    }

    private static string GenerateEnvName(string url)
    {
        // "cst-hfx-tst-01.crm.dynamics.com" -> "cst-hfx-tst-01"
        var parts = url.Split('.');
        if (parts.Length > 0)
        {
            var name = parts[0];
            // Capitalize first letter, replace dashes with spaces for readability
            return name.Length > 0
                ? char.ToUpper(name[0]) + name[1..]
                : url;
        }
        return url;
    }
}
