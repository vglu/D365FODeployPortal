@page "/packages"
@implements IDisposable
@inject PackageService PkgService
@inject MergeService MergeSvc
@inject AzureDevOpsBuildService BuildService
@inject ISettingsService SettingsSvc
@inject ISecretProtectionService SecretSvc
@inject NavigationManager NavManager
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Packages</PageTitle>

@* Upload area with drop zone *@
<MudPaper Class="pa-4 mb-4" Elevation="2">
    <div id="packages-drop-zone" @ref="_dropZoneRef" class="packages-drop-zone @(_dropZoneActive ? "packages-drop-zone-active" : "")">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
            <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Upload Package</MudText>
            <MudSpacer />
            <MudSelect @bind-Value="_uploadType" Label="Package type" Variant="Variant.Outlined"
                       Margin="Margin.Dense" Style="width:160px" Dense="true">
                <MudSelectItem Value="@("Auto")">Auto-detect</MudSelectItem>
                <MudSelectItem Value="@("LCS")">LCS</MudSelectItem>
                <MudSelectItem Value="@("Unified")">Unified</MudSelectItem>
                <MudSelectItem Value="@("Other")">Other</MudSelectItem>
            </MudSelect>
            <MudFileUpload @ref="_fileUpload" T="IReadOnlyList<IBrowserFile>" FilesChanged="@OnFilesSelected" Accept=".zip"
                           MaximumFileCount="20" Hidden="true" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.CloudUpload"
                       OnClick="@OpenFilePicker" Disabled="@_uploading">
                @(_uploading ? _uploadProgress : "Select ZIP file(s)")
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Build"
                       OnClick="@OpenLoadFromBuildDialog" Disabled="@_uploading">
                Load from build
            </MudButton>
        </MudStack>
        <MudText Typo="Typo.body2" Class="mt-2 mud-text-secondary">or drag and drop .zip files here</MudText>
    </div>
    @if (_uploading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mt-2" />
    }
    @if (!string.IsNullOrEmpty(_lastDetectedType))
    {
        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2" CloseIconClicked="@(() => _lastDetectedType = "")">
            Auto-detected package type: <strong>@_lastDetectedType</strong>
        </MudAlert>
    }
</MudPaper>

@* Package tabs: Active | Archive (like Deployments) *@
<MudTabs Elevation="2" Rounded="true" Color="Color.Primary" @bind-ActivePanelIndex="_packagesTabIndex" Class="mb-4">
    <MudTabPanel Text="Active Packages" Icon="@Icons.Material.Filled.Inventory2">
@* Active package table *@
<MudTable @ref="_table" Items="@_packages" Dense="true" Hover="true" Elevation="0" Loading="@_loading"
          MultiSelection="true" @bind-SelectedItems="_selectedForMerge" SelectOnRowClick="false"
          Filter="new Func<Package, bool>(FilterFunc)" FixedHeader="true"
          Breakpoint="Breakpoint.None">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Active Packages</MudText>
        @if (_selectedForMerge.Count >= 2)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.MergeType" Class="ml-3"
                       OnClick="@MergeSelected" Disabled="@_merging">
                @(_merging ? "Merging..." : $"Merge {_selectedForMerge.Count} packages")
            </MudButton>
        }
        @if (_selectedForMerge.Count >= 1)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Delete" Class="ml-3"
                       OnClick="@ConfirmDeleteSelected" Disabled="@_deleting">
                @(_deleting ? "Deleting..." : $"Delete {_selectedForMerge.Count} package(s)")
            </MudButton>
        }
        <MudSpacer />
        <MudTextField @bind-Value="_searchText" Placeholder="Search..." Variant="Variant.Outlined"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" DebounceInterval="200" Margin="Margin.Dense"
                      Clearable="true" Style="max-width:280px" />
    </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="new Func<Package, object>(p => p.Name)">Name</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<Package, object>(p => p.OriginalFileName)">File</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<Package, object>(p => p.PackageType)">Type</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<Package, object>(p => p.FileSizeBytes)">Size</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<Package, object>(p => p.UploadedAt)" InitialDirection="SortDirection.Descending">Uploaded</MudTableSortLabel></MudTh>
        <MudTh Style="width:44px">
            <MudTooltip Text="License Files"><MudIcon Icon="@Icons.Material.Filled.Gavel" Size="Size.Small" /></MudTooltip>
        </MudTh>
        <MudTh Style="width:90px">Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Name">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                @if ((context.PackageType == "Merged" || context.ParentMergeFromId.HasValue) && !string.IsNullOrEmpty(context.MergeSourceNames))
                {
                    <MudIconButton Icon="@(_expandedRows.Contains(context.Id) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                   Size="Size.Small" OnClick="@(() => ToggleExpand(context.Id))"
                                   title="Show source packages" />
                }
                <span>@context.Name</span>
            </MudStack>
        </MudTd>
        <MudTd DataLabel="File">
            <span class="mud-text-secondary" style="font-size:0.85rem">@context.OriginalFileName</span>
        </MudTd>
        <MudTd DataLabel="Type">
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                     Color="@PkgTypeColor(context.PackageType)">
                @context.PackageType
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Size">@FormatSize(context.FileSizeBytes)</MudTd>
        <MudTd DataLabel="Uploaded">
            <MudTooltip Text="@context.UploadedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")">
                <span>@context.UploadedAt.ToLocalTime().ToString("MM-dd HH:mm")</span>
            </MudTooltip>
        </MudTd>
        <MudTd Style="text-align:center">
            @if (HasLicenseFiles(context))
            {
                <MudTooltip Text="@GetLicenseTooltip(context)">
                    <MudIcon Icon="@Icons.Material.Filled.Gavel" Size="Size.Small" Color="Color.Warning" />
                </MudTooltip>
            }
        </MudTd>
        <MudTd>
            <MudStack Row="true" Spacing="0">
                @* Download button *@
                <MudTooltip Text="Download">
                    <MudIconButton Icon="@Icons.Material.Filled.Download" Size="Size.Small" Color="Color.Primary"
                                   OnClick="@(() => DownloadPackage(context))" />
                </MudTooltip>
                @* Actions menu *@
                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small"
                         AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="true">
                    <MudMenuItem Icon="@Icons.Material.Filled.FolderOpen"
                                 Href="@($"/packages/{context.Id}/details")">
                        Manage content
                    </MudMenuItem>
                    <MudDivider />
                    @if (context.PackageType == "LCS" || context.PackageType == "Merged")
                    {
                        <MudMenuItem Icon="@Icons.Material.Filled.Transform"
                                     OnClick="@(() => ConvertToUnified(context))"
                                     Disabled="@(_converting.Contains(context.Id))">
                            @if (_converting.Contains(context.Id))
                            {
                                @("Converting...")
                            }
                            else
                            {
                                @("Convert to Unified")
                            }
                        </MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.FileDownload"
                                     OnClick="@(() => ConvertAndDownload(context, "Unified"))"
                                     Disabled="@(_converting.Contains(context.Id))">
                            Download as Unified
                        </MudMenuItem>
                        <MudDivider />
                    }
                    @if (context.PackageType == "Unified")
                    {
                        <MudMenuItem Icon="@Icons.Material.Filled.Transform"
                                     OnClick="@(() => ConvertToLcs(context))"
                                     Disabled="@(_converting.Contains(context.Id))">
                            @if (_converting.Contains(context.Id))
                            {
                                @("Converting...")
                            }
                            else
                            {
                                @("Convert to LCS")
                            }
                        </MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.FileDownload"
                                     OnClick="@(() => ConvertAndDownload(context, "LCS"))"
                                     Disabled="@(_converting.Contains(context.Id))">
                            Download as LCS
                        </MudMenuItem>
                        <MudDivider />
                    }
                    <MudMenuItem Icon="@Icons.Material.Filled.UploadFile"
                                 OnClick="@(() => OpenLicenseUpload(context))">
                        Upload License Files
                    </MudMenuItem>
                    @if (HasLicenseFiles(context))
                    {
                        <MudMenuItem Icon="@Icons.Material.Filled.FileDownload"
                                     OnClick="@(() => DownloadLicenses(context))">
                            Download License Files
                        </MudMenuItem>
                    }
                    <MudMenuItem Icon="@Icons.Material.Filled.Refresh"
                                 OnClick="@(() => RefreshLicenseInfo(context))">
                        Refresh license info
                    </MudMenuItem>
                    <MudDivider />
                    <MudMenuItem Icon="@Icons.Material.Filled.Edit"
                                 OnClick="@(() => OpenEditPackage(context))">
                        Edit
                    </MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.Archive"
                                 OnClick="@(() => ArchivePackage(context))">
                        Archive
                    </MudMenuItem>
                    <MudDivider />
                    <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error"
                                 OnClick="@(() => DeletePackage(context))">
                        Delete
                    </MudMenuItem>
                </MudMenu>
            </MudStack>
        </MudTd>
    </RowTemplate>
    <ChildRowContent>
        @if (!string.IsNullOrEmpty(context.MergeSourceNames) && _expandedRows.Contains(context.Id))
        {
            <MudTr>
                <td colspan="8" style="padding:0">
                    <MudPaper Class="pa-3 ma-2" Elevation="0"
                              Style="background:var(--mud-palette-background-gray)">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                            @if (context.PackageType == "Merged")
                            {
                                <MudIcon Icon="@Icons.Material.Filled.MergeType" Size="Size.Small" Color="Color.Secondary" />
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Merged from:</MudText>
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Transform" Size="Size.Small" Color="Color.Info" />
                                <MudText Typo="Typo.subtitle2" Color="Color.Info">Converted from:</MudText>
                            }
                        </MudStack>
                        <MudStack Spacing="1">
                            @foreach (var sourceName in GetMergeSourceNames(context))
                            {
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Small" />
                                    <MudText Typo="Typo.body2">@sourceName</MudText>
                                </MudStack>
                            }
                        </MudStack>
                    </MudPaper>
                </td>
            </MudTr>
        }
    </ChildRowContent>
    <NoRecordsContent>
        <MudText Color="Color.Warning" Class="pa-4">No active packages. Upload or restore from Archive.</MudText>
    </NoRecordsContent>
</MudTable>
    </MudTabPanel>

    <MudTabPanel Text="Archive" Icon="@Icons.Material.Filled.Archive">
        <MudTable Items="@_archivedPackages" Dense="true" Hover="true" Elevation="0" Loading="@_loadingArchive" FixedHeader="true" Class="mt-4">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Archived Packages</MudText>
                <MudSpacer />
            </ToolBarContent>
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>File</MudTh>
                <MudTh>Type</MudTh>
                <MudTh>Size</MudTh>
                <MudTh>Uploaded</MudTh>
                <MudTh>Archived</MudTh>
                <MudTh Style="width:120px">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">@context.Name</MudTd>
                <MudTd DataLabel="File"><span class="mud-text-secondary" style="font-size:0.85rem">@context.OriginalFileName</span></MudTd>
                <MudTd DataLabel="Type">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@PkgTypeColor(context.PackageType)">@context.PackageType</MudChip>
                </MudTd>
                <MudTd DataLabel="Size">@FormatSize(context.FileSizeBytes)</MudTd>
                <MudTd DataLabel="Uploaded">@context.UploadedAt.ToLocalTime().ToString("MM-dd HH:mm")</MudTd>
                <MudTd DataLabel="Archived">@(context.ArchivedAt?.ToLocalTime().ToString("MM-dd HH:mm") ?? "-")</MudTd>
                <MudTd DataLabel="Actions">
                    <MudTooltip Text="Download">
                        <MudIconButton Icon="@Icons.Material.Filled.Download" Size="Size.Small" Color="Color.Primary"
                                       OnClick="@(() => DownloadPackage(context))" />
                    </MudTooltip>
                    <MudTooltip Text="Manage content">
                        <MudIconButton Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Small"
                                       Href="@($"/packages/{context.Id}/details")" Target="_self" />
                    </MudTooltip>
                    <MudTooltip Text="Restore">
                        <MudIconButton Icon="@Icons.Material.Filled.Unarchive" Size="Size.Small" Color="Color.Success"
                                       OnClick="@(() => RestorePackage(context))" />
                    </MudTooltip>
                    <MudTooltip Text="Delete permanently">
                        <MudIconButton Icon="@Icons.Material.Filled.DeleteForever" Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => DeletePackagePermanently(context))" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Color="Color.Default" Class="pa-4">No archived packages.</MudText>
            </NoRecordsContent>
        </MudTable>
    </MudTabPanel>
</MudTabs>

@* Merge name dialog *@
<MudDialog @bind-Visible="_mergeDialogVisible" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.MergeType" Color="Color.Secondary" />
            <MudText Typo="Typo.h6">Merge Packages</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (_mergeStrategy != null)
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                @if (_mergeStrategy == "LCS")
                {
                    <span><strong>LCS Merge</strong> — AOSService contents + HotfixInstallationInfo.xml will be combined</span>
                }
                else
                {
                    <span><strong>UDE Merge</strong> — folder contents will be combined + ImportConfig.xml updated</span>
                }
            </MudAlert>
        }
        else
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mb-3">
                <strong>Incompatible package types!</strong> Cannot merge LCS and Unified packages together.
                Select packages of the same type.
            </MudAlert>
        }

        @if (_mergeStrategy == "LCS" && _mergeConflicts.Count > 0)
        {
            <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                <strong>@_mergeConflicts.Count model(s)</strong> appear in more than one package with different versions. Choose what to keep in the merged package.
            </MudAlert>
            <MudText Typo="Typo.body2" Class="mb-2">Apply same action to all:</MudText>
            <MudSelect @bind-Value="_mergeConflictActionForAll" Label="For all conflicting models" Variant="Variant.Outlined" Dense="true" Class="mb-3" Style="min-width: 280px;">
                <MudSelectItem Value="@(-1)">Keep both (all variants)</MudSelectItem>
                @for (var idx = 0; idx < _mergePackages.Count; idx++)
                {
                    var i = idx;
                    <MudSelectItem Value="@i">Keep from package @(i + 1): @_mergePackages[i].Name</MudSelectItem>
                }
            </MudSelect>
            <MudList T="LcsModelConflict" Dense="true" Class="mb-3" Style="max-height: 200px; overflow-y: auto;">
                @foreach (var c in _mergeConflicts)
                {
                    <MudListItem T="LcsModelConflict">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.body2"><strong>@c.ModuleName</strong></MudText>
                            @foreach (var v in c.Variants)
                            {
                                <MudText Typo="Typo.caption" Class="mud-secondary-text">
                                    Package @(v.PackageIndex + 1): @string.Join(", ", v.FileNames) @(string.IsNullOrEmpty(v.Version) ? "" : $"({v.Version})")
                                </MudText>
                            }
                        </MudStack>
                    </MudListItem>
                }
            </MudList>
        }

        <MudText Typo="Typo.body2" Class="mb-3">
            Merging @_mergePackages.Count packages:
        </MudText>
        <MudList T="string" Dense="true">
            @foreach (var pkg in _mergePackages)
            {
                <MudListItem T="string" Icon="@Icons.Material.Filled.Inventory2" IconColor="Color.Primary">
                    @pkg.Name
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                             Color="@PkgTypeColor(pkg.PackageType)" Class="ml-2">
                        @pkg.PackageType
                    </MudChip>
                    <span class="mud-text-secondary ml-1">(@FormatSize(pkg.FileSizeBytes))</span>
                </MudListItem>
            }
        </MudList>
        <MudTextField @bind-Value="_mergeName" Label="Merged package name" Variant="Variant.Outlined"
                      Class="mt-4" Required="true" Immediate="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _mergeDialogVisible = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="@ConfirmMerge"
                   Disabled="@(string.IsNullOrWhiteSpace(_mergeName) || _merging || _mergeStrategy == null)"
                   StartIcon="@Icons.Material.Filled.MergeType">
            @if (_merging)
            {
                @("Merging...")
            }
            else if (_mergeStrategy != null)
            {
                @($"Merge ({_mergeStrategy})")
            }
            else
            {
                @("Merge")
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@* Edit package dialog (Name + URL) *@
<MudDialog @bind-Visible="_editPackageDialogVisible" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Edit Package</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_editPackageName" Label="Package name" Variant="Variant.Outlined" Immediate="true" Class="mt-2" />
        <MudTextField @bind-Value="_editPackageUrl" Label="URL (e.g. DevOps task link)" Variant="Variant.Outlined" Immediate="true" Class="mt-2"
                      Placeholder="https://dev.azure.com/org/project/_workitems/edit/12345"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Link" Clearable="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _editPackageDialogVisible = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@SaveEditPackage"
                   StartIcon="@Icons.Material.Filled.Save" Disabled="@string.IsNullOrWhiteSpace(_editPackageName)">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@* Load from build dialog — Step 1: select build, Step 2: select artifacts *@
<MudDialog @bind-Visible="_loadFromBuildVisible" Options="@(new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true })">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Build" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Load package(s) from Azure DevOps build</MudText>
            @if (_loadFromBuildStep == 2)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Secondary">Step 2: Artifacts</MudChip>
            }
            else
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Default">Step 1: Select build</MudChip>
            }
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (_loadFromBuildStep == 1)
        {
                <MudStack Spacing="2">
                <MudStack Row="true" Spacing="2">
                    <MudTextField T="string" Value="@_buildOrg" ValueChanged="OnOrganizationInputChanged"
                                 Label="Organization" Placeholder="org or build URL"
                                 Variant="Variant.Outlined" Immediate="true" Style="min-width:140px" />
                    <MudTextField @bind-Value="_buildProject" Label="Project" Variant="Variant.Outlined" Immediate="true" Style="min-width:200px" />
                </MudStack>
                @* PAT: saved or enter new *@
                @if (_hasSavedPat && !_showPatField)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudText Typo="Typo.body2">PAT: @_savedPatMasked</MudText>
                        <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@(() => { _showPatField = true; })">Change</MudButton>
                        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Error" OnClick="@ClearSavedPat">Clear saved</MudButton>
                    </MudStack>
                }
                @if (_showPatField || !_hasSavedPat)
                {
                    <MudTextField @bind-Value="_buildPat" Label="Personal Access Token (PAT)" Placeholder="PAT with Build (Read) scope"
                                 Variant="Variant.Outlined" InputType="InputType.Password" Immediate="true"
                                 Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock" />
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudCheckBox @bind-Value="_savePatChecked" T="bool" Label="Save PAT for next time" />
                        @if (_hasSavedPat)
                        {
                            <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@(() => { _showPatField = false; })">Use saved instead</MudButton>
                        }
                    </MudStack>
                }
                @if (!string.IsNullOrEmpty(_buildParseError))
                {
                    <MudAlert Severity="Severity.Error" Dense="true" CloseIconClicked="@(() => _buildParseError = "")">@_buildParseError</MudAlert>
                }
                <MudDivider />
                <MudText Typo="Typo.subtitle2">Filters (optional)</MudText>
                <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                    <MudTextField @bind-Value="_filterPipelineName" Label="Pipeline name" Placeholder="Part of name"
                                 Variant="Variant.Outlined" Immediate="true" Style="min-width:180px" Clearable="true" />
                    <MudDatePicker @bind-Date="_filterDateFrom" Label="Date from" Variant="Variant.Outlined" DateFormat="yyyy-MM-dd" Clearable="true" />
                    <MudDatePicker @bind-Date="_filterDateTo" Label="Date to" Variant="Variant.Outlined" DateFormat="yyyy-MM-dd" Clearable="true" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search"
                               OnClick="@OnLoadBuilds" Disabled="@(_loadingBuilds || !HasEffectivePat())">
                        @(_loadingBuilds ? "Loading..." : "Search builds")
                    </MudButton>
                </MudStack>
                <MudAlert Severity="Severity.Info" Dense="true">
                    Showing last 10 completed builds. Use filters (pipeline name, date) to find the build you need.
                </MudAlert>
                @if (_builds.Count > 0)
                {
                    <MudTable T="BuildInfo" Items="@_builds" Dense="true" Hover="true" Breakpoint="Breakpoint.None" Style="max-height:280px; overflow:auto">
                        <HeaderContent>
                            <MudTh>Build #</MudTh>
                            <MudTh>Pipeline</MudTh>
                            <MudTh>Project</MudTh>
                            <MudTh>Result</MudTh>
                            <MudTh>Finished</MudTh>
                            <MudTh Style="width:100px">Action</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Build #">@context.BuildNumber</MudTd>
                            <MudTd DataLabel="Pipeline">@context.DefinitionName</MudTd>
                            <MudTd DataLabel="Project">@context.ProjectName</MudTd>
                            <MudTd DataLabel="Result">
                                <MudChip T="string" Size="Size.Small" Color="@(context.Result == "succeeded" ? Color.Success : context.Result == "failed" ? Color.Error : Color.Default)">
                                    @context.Result
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="Finished">@FormatBuildDate(context.FinishTime)</MudTd>
                            <MudTd DataLabel="Action">
                                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                           OnClick="@(() => SelectBuildAndLoadArtifacts(context))">
                                    Select
                                </MudButton>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudStack>
        }
        else
        {
            @* Step 2: artifacts for selected build *@
            @if (_selectedBuild != null)
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                    Build: <strong>@_selectedBuild.BuildNumber</strong> — @_selectedBuild.DefinitionName
                </MudAlert>
                <MudButton Size="Size.Small" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack" Class="mb-2"
                           OnClick="@BackToBuildList">Back to build list</MudButton>
            }
            @if (_loadingArtifacts)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-3" />
            }
            @if (!string.IsNullOrEmpty(_buildParseError))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mb-3" CloseIconClicked="@(() => _buildParseError = "")">@_buildParseError</MudAlert>
            }
            @if (_buildArtifacts.Count > 0)
            {
                <MudText Typo="Typo.subtitle2" Class="mb-2">Select artifacts or files inside (up to 8 levels):</MudText>
                <MudPaper Outlined="true" Class="pa-2 mb-2" Style="max-height:320px; overflow-y:auto">
                    <MudTreeView T="string" Dense="true" Hover="true">
                    <MudTreeViewItem Text="Artifacts" Expanded="true" CanExpand="true">
                        <ChildContent>
                            @foreach (var a in _buildArtifacts)
                            {
                                var artifactName = a.Name;
                                var cacheCount = _artifactContentsCache.TryGetValue(artifactName, out var cachedList) ? cachedList.Count : 0;
                                <MudTreeViewItem T="string" Value="@artifactName" CanExpand="true" @key="@($"{artifactName}-{cacheCount}")"
                                                Expanded="@_expandedArtifacts.Contains(artifactName)"
                                                ExpandedChanged="@(async (bool expanded) => await OnArtifactExpanded(artifactName, expanded))">
                                    <Content>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <span @onclick="@((_) => { })" @onclick:stopPropagation="true">
                                                <MudIconButton Icon="@(_expandedArtifacts.Contains(artifactName) ? Icons.Material.Filled.ExpandMore : Icons.Material.Filled.ChevronRight)"
                                                              Size="Size.Small" OnClick="@(async () => await ToggleArtifactExpand(artifactName))"
                                                              title="@(_expandedArtifacts.Contains(artifactName) ? "Collapse" : "Expand to see files")" />
                                            </span>
                                            <MudCheckBox T="bool" Value="@_selectedArtifactNames.Contains(artifactName)"
                                                        ValueChanged="@(v => { if (v) _selectedArtifactNames.Add(artifactName); else _selectedArtifactNames.Remove(artifactName); StateHasChanged(); })" />
                                            <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Small" Color="Color.Default" />
                                            <MudText Typo="Typo.body2">@artifactName</MudText>
                                        </MudStack>
                                    </Content>
                                    <ChildContent>
                                        @if (_loadingContentsFor == artifactName)
                                        {
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Class="pl-4"><MudProgressCircular Size="Size.Small" Indeterminate="true" /> <MudText Typo="Typo.body2">Loading...</MudText></MudStack>
                                        }
                                        else if (_artifactContentsCache.TryGetValue(artifactName, out var nodes) && nodes.Count > 0)
                                        {
                                            @foreach (var node in nodes.OrderBy(n => n.IsFolder ? 0 : 1).ThenBy(n => n.Name))
                                            {
                                                <ArtifactTreeNode ArtifactName="@artifactName" Node="node" SelectedKeys="_selectedArtifactNames"
                                                                SelectionChanged="OnArtifactNodeSelectionChanged" />
                                            }
                                        }
                                    </ChildContent>
                                </MudTreeViewItem>
                            }
                        </ChildContent>
                    </MudTreeViewItem>
                    </MudTreeView>
                </MudPaper>
            }
        }
    </DialogContent>
    <DialogActions>
        @if (_loadFromBuildStep == 2)
        {
            <MudButton OnClick="@BackToBuildList">Back</MudButton>
        }
        <MudButton OnClick="@(() => _loadFromBuildVisible = false)">Cancel</MudButton>
        @if (_loadFromBuildStep == 2)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Download"
                       OnClick="@OnDownloadFromBuildAndAdd"
                       Disabled="@(_downloadingFromBuild || _selectedArtifactNames.Count == 0)">
                @(_downloadingFromBuild ? "Downloading..." : "Download and add")
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@* Hidden license file upload *@
<MudFileUpload @ref="_licFileUpload" T="IReadOnlyList<IBrowserFile>" FilesChanged="@OnLicenseFilesSelected"
               Accept=".txt,.xml" Hidden="true" MaximumFileCount="20" />

@code {
    private MudTable<Package>? _table;
    private MudFileUpload<IReadOnlyList<IBrowserFile>>? _fileUpload;
    private MudFileUpload<IReadOnlyList<IBrowserFile>>? _licFileUpload;
    private ElementReference _dropZoneRef;
    private bool _dropZoneActive;
    private string _uploadProgress = "";
    private int? _licUploadTargetPkgId;
    private List<Package> _packages = new();
    private HashSet<Package> _selectedForMerge = new();
    private HashSet<int> _expandedRows = new();
    private bool _loading = true;
    private bool _uploading;
    private bool _merging;
    private bool _deleting;
    private string _searchText = "";
    private string _uploadType = "Auto";
    private string _lastDetectedType = "";
    private int _packagesTabIndex = 0;
    private List<Package> _archivedPackages = new();
    private bool _loadingArchive = true;
    private IJSObjectReference? _dropZoneJs;
    private DotNetObjectReference<Packages>? _dotNetRef;

    private HashSet<int> _converting = new();

    // Merge dialog
    private bool _mergeDialogVisible;
    private string _mergeName = "";
    private string? _mergeStrategy;
    private List<Package> _mergePackages = new();
    private List<LcsModelConflict> _mergeConflicts = new();
    /// <summary>-1 = keep both for all; 0,1,2,... = keep variant from that package index for all.</summary>
    private int _mergeConflictActionForAll = -1;

    // Load from build dialog
    private bool _loadFromBuildVisible;
    private int _loadFromBuildStep = 1;
    private string _buildPat = "";
    private string _buildParseError = "";
    private string _buildOrg = "";
    private string _buildProject = "";
    private int _buildId;
    private List<BuildInfo> _builds = new();
    private BuildInfo? _selectedBuild;
    private List<BuildArtifactInfo> _buildArtifacts = new();
    private HashSet<string> _selectedArtifactNames = new();
    private Dictionary<string, List<ArtifactNode>> _artifactContentsCache = new();
    private HashSet<string> _expandedArtifacts = new();
    private string? _loadingContentsFor;
    private bool _loadingArtifacts;
    private bool _loadingBuilds;
    private bool _downloadingFromBuild;
    private bool _hasSavedPat;
    private bool _showPatField;
    private string _savedPatMasked = "";
    private bool _savePatChecked;
    private string _filterPipelineName = "";
    private DateTime? _filterDateFrom;
    private DateTime? _filterDateTo;
    private void OnOrganizationInputChanged(string value)
    {
        var url = (value ?? "").Trim();
        if ((url.StartsWith("http://", StringComparison.OrdinalIgnoreCase) || url.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
            && (url.Contains("visualstudio.com", StringComparison.OrdinalIgnoreCase) || url.Contains("dev.azure.com", StringComparison.OrdinalIgnoreCase))
            && url.Contains("_build", StringComparison.OrdinalIgnoreCase)
            && AzureDevOpsBuildService.TryParseBuildUrl(url, out var org, out var project, out _))
        {
            _buildOrg = org;
            _buildProject = project;
            _buildParseError = "";
        }
        else
        {
            _buildOrg = value ?? "";
        }
        InvokeAsync(StateHasChanged);
    }

    private void OpenLoadFromBuildDialog()
    {
        _loadFromBuildStep = 1;
        _buildOrg = SettingsSvc.AzureDevOpsOrganization ?? "";
        _buildProject = SettingsSvc.AzureDevOpsProject ?? "";
        _buildPat = "";
        _buildParseError = "";
        _builds.Clear();
        _selectedBuild = null;
        _buildArtifacts.Clear();
        _selectedArtifactNames.Clear();
        _filterPipelineName = "";
        _filterDateFrom = null;
        _filterDateTo = null;
        _hasSavedPat = !string.IsNullOrEmpty(SettingsSvc.AzureDevOpsPatEncrypted);
        _showPatField = false;
        _savePatChecked = false;
        try
        {
            _savedPatMasked = _hasSavedPat ? SecretSvc.MaskSecret(SecretSvc.Decrypt(SettingsSvc.AzureDevOpsPatEncrypted)) : "";
        }
        catch { _savedPatMasked = "****"; }
        _loadFromBuildVisible = true;
    }

    private string? GetEffectivePat()
    {
        if (!string.IsNullOrWhiteSpace(_buildPat)) return _buildPat.Trim();
        if (!_hasSavedPat || string.IsNullOrEmpty(SettingsSvc.AzureDevOpsPatEncrypted)) return null;
        try { return SecretSvc.Decrypt(SettingsSvc.AzureDevOpsPatEncrypted); }
        catch { return null; }
    }

    private bool HasEffectivePat() => !string.IsNullOrEmpty(GetEffectivePat());

    private void ClearSavedPat()
    {
        SettingsSvc.SaveAzureDevOpsSettings("", null, null);
        _hasSavedPat = false;
        _savedPatMasked = "";
        _buildPat = "";
        _showPatField = true;
        StateHasChanged();
    }

    private static string FormatBuildDate(string finishTime)
    {
        if (string.IsNullOrEmpty(finishTime)) return "";
        if (DateTime.TryParse(finishTime, null, System.Globalization.DateTimeStyles.RoundtripKind, out var dt))
            return dt.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
        return finishTime;
    }

    private async Task OnLoadBuilds()
    {
        var pat = GetEffectivePat();
        if (string.IsNullOrEmpty(pat) || string.IsNullOrWhiteSpace(_buildOrg) || string.IsNullOrWhiteSpace(_buildProject))
        {
            _buildParseError = "Enter Organization, Project, and PAT (or use saved PAT).";
            return;
        }
        _buildParseError = "";
        _loadingBuilds = true;
        StateHasChanged();
        try
        {
            var minTime = _filterDateFrom.HasValue ? (DateTime?)_filterDateFrom.Value.Date : null;
            var maxTime = _filterDateTo.HasValue ? (DateTime?)_filterDateTo.Value.Date.AddDays(1).AddTicks(-1) : null;
            _builds = await BuildService.ListBuildsAsync(_buildOrg.Trim(), _buildProject.Trim(), pat, top: 10,
                definitionIds: null, definitionNameFilter: string.IsNullOrWhiteSpace(_filterPipelineName) ? null : _filterPipelineName.Trim(),
                minTime: minTime, maxTime: maxTime);
            if (_builds.Count == 0)
                Snackbar.Add("No completed builds found. Try different filters.", Severity.Info);
            if (_savePatChecked && !string.IsNullOrWhiteSpace(_buildPat))
            {
                SettingsSvc.SaveAzureDevOpsSettings(SecretSvc.Encrypt(_buildPat.Trim()), _buildOrg.Trim(), _buildProject.Trim());
                _hasSavedPat = true;
                _savedPatMasked = SecretSvc.MaskSecret(_buildPat.Trim());
                _showPatField = false;
                _savePatChecked = false;
                Snackbar.Add("PAT and project saved.", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            _buildParseError = ex.Message;
            _builds.Clear();
        }
        finally
        {
            _loadingBuilds = false;
            StateHasChanged();
        }
    }

    private async Task SelectBuildAndLoadArtifacts(BuildInfo build)
    {
        var pat = GetEffectivePat();
        if (string.IsNullOrEmpty(pat)) return;
        _selectedBuild = build;
        _buildId = build.Id;
        _buildParseError = "";
        _loadingArtifacts = true;
        _loadFromBuildStep = 2;
        StateHasChanged();
        try
        {
            _buildArtifacts = await BuildService.ListArtifactsAsync(_buildOrg, _buildProject, build.Id, pat);
            _selectedArtifactNames.Clear();
            if (_buildArtifacts.Count == 0)
                Snackbar.Add("No artifacts in this build.", Severity.Info);
        }
        catch (Exception ex)
        {
            _buildParseError = ex.Message;
            _buildArtifacts.Clear();
        }
        finally
        {
            _loadingArtifacts = false;
            StateHasChanged();
        }
    }

    private void BackToBuildList()
    {
        _loadFromBuildStep = 1;
        _selectedBuild = null;
        _buildArtifacts.Clear();
        _selectedArtifactNames.Clear();
        _artifactContentsCache.Clear();
        _expandedArtifacts.Clear();
        _loadingContentsFor = null;
        _buildParseError = "";
        StateHasChanged();
    }

    private async Task ToggleArtifactExpand(string artifactName)
    {
        await OnArtifactExpanded(artifactName, !_expandedArtifacts.Contains(artifactName));
    }

    private async Task OnArtifactExpanded(string artifactName, bool expanded)
    {
        if (expanded)
            _expandedArtifacts.Add(artifactName);
        else
            _expandedArtifacts.Remove(artifactName);
        if (expanded && !_artifactContentsCache.ContainsKey(artifactName))
        {
            var pat = GetEffectivePat();
            if (string.IsNullOrEmpty(pat)) return;
            _loadingContentsFor = artifactName;
            StateHasChanged();
            try
            {
                var nodes = await BuildService.GetArtifactContentsAsync(_buildOrg, _buildProject, _buildId, artifactName, pat, maxDepth: 8);
                _artifactContentsCache[artifactName] = nodes;
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Could not load contents of '{artifactName}': {ex.Message}", Severity.Warning);
                _artifactContentsCache[artifactName] = new List<ArtifactNode>();
            }
            finally
            {
                _loadingContentsFor = null;
                StateHasChanged();
            }
        }
        StateHasChanged();
    }

    private async Task OnArtifactNodeSelectionChanged((string key, bool selected) evt)
    {
        if (evt.selected)
            _selectedArtifactNames.Add(evt.key);
        else
            _selectedArtifactNames.Remove(evt.key);
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnDownloadFromBuildAndAdd()
    {
        var toDownload = _selectedArtifactNames.ToList();
        if (toDownload.Count == 0) return;
        var pat = GetEffectivePat();
        if (string.IsNullOrEmpty(pat)) { Snackbar.Add("PAT is required.", Severity.Warning); return; }
        _downloadingFromBuild = true;
        StateHasChanged();
        var added = 0;
        var fail = 0;
        try
        {
            var devOpsUrl = $"https://dev.azure.com/{Uri.EscapeDataString(_buildOrg)}/{Uri.EscapeDataString(_buildProject)}/_build/results?buildId={_buildId}";
            try
            {
                var workItems = await BuildService.GetBuildWorkItemsRefsAsync(_buildOrg, _buildProject, _buildId, pat, top: 1);
                if (workItems.Count > 0 && !string.IsNullOrEmpty(workItems[0].Url))
                    devOpsUrl = workItems[0].Url;
            }
            catch { /* fallback to build URL */ }
            foreach (var key in toDownload)
            {
                try
                {
                    Stream stream;
                    string fileName;
                    var pipe = key.IndexOf('|');
                    if (pipe >= 0)
                    {
                        var artifactName = key[..pipe];
                        var relativePath = key[(pipe + 1)..];
                        var isFolder = relativePath.EndsWith("/");
                        if (isFolder)
                            relativePath = relativePath.TrimEnd('/');
                        if (isFolder)
                        {
                            stream = await BuildService.DownloadArtifactFolderAsZipAsync(_buildOrg, _buildProject, _buildId, artifactName, relativePath, pat);
                            var folderName = Path.GetFileName(relativePath.TrimEnd('/'));
                            if (string.IsNullOrEmpty(folderName)) folderName = relativePath.Replace("/", "_");
                            fileName = folderName.EndsWith(".zip", StringComparison.OrdinalIgnoreCase) ? folderName : folderName + ".zip";
                        }
                        else
                        {
                            stream = await BuildService.DownloadArtifactEntryAsync(_buildOrg, _buildProject, _buildId, artifactName, relativePath, pat);
                            fileName = Path.GetFileName(relativePath);
                            if (string.IsNullOrEmpty(fileName)) fileName = key.Replace("|", "_") + ".zip";
                        }
                    }
                    else
                    {
                        stream = await BuildService.DownloadArtifactAsync(_buildOrg, _buildProject, _buildId, key, pat);
                        fileName = key.EndsWith(".zip", StringComparison.OrdinalIgnoreCase) ? key : key + ".zip";
                    }
                    await using (stream)
                        await PkgService.UploadAsync(fileName, stream, devOpsTaskUrl: devOpsUrl);
                    added++;
                }
                catch (Exception ex)
                {
                    fail++;
                    Snackbar.Add($"'{key}': {ex.Message}", Severity.Error);
                }
            }
            if (added > 0)
            {
                Snackbar.Add(added == 1 ? "1 package added from build." : $"{added} packages added from build.", Severity.Success);
                _loadFromBuildVisible = false;
                await LoadData();
            }
        }
        finally
        {
            _downloadingFromBuild = false;
            StateHasChanged();
        }
    }

    private async Task OpenFilePicker()
    {
        if (_fileUpload != null)
            await _fileUpload.OpenFilePickerAsync();
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        await LoadArchivedData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _dropZoneRef.Id != null)
        {
            try
            {
                _dotNetRef = DotNetObjectReference.Create(this);
                _dropZoneJs = await JS.InvokeAsync<IJSObjectReference>("import", "./js/packages-upload.js");
                await _dropZoneJs.InvokeVoidAsync("initDropZone", "packages-drop-zone", NavManager.BaseUri.TrimEnd('/'), _dotNetRef);
            }
            catch (Exception) { /* JS or module not available */ }
        }
    }

    public void Dispose() => _dotNetRef?.Dispose();

    private async Task LoadData()
    {
        _loading = true;
        _packages = await PkgService.GetAllAsync();
        _selectedForMerge.Clear();
        _expandedRows.Clear();
        _loading = false;
    }

    // ===== Filter =====
    private bool FilterFunc(Package p)
    {
        if (string.IsNullOrWhiteSpace(_searchText)) return true;
        return p.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || p.OriginalFileName.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || p.PackageType.Contains(_searchText, StringComparison.OrdinalIgnoreCase);
    }

    // ===== Expand/Collapse =====
    private void ToggleExpand(int id)
    {
        if (!_expandedRows.Remove(id))
            _expandedRows.Add(id);
    }

    private static List<string> GetMergeSourceNames(Package pkg)
    {
        if (string.IsNullOrEmpty(pkg.MergeSourceNames)) return new();
        try
        {
            return System.Text.Json.JsonSerializer.Deserialize<List<string>>(pkg.MergeSourceNames) ?? new();
        }
        catch
        {
            return new() { pkg.MergeSourceNames };
        }
    }

    // ===== Upload =====
    private async Task OnFilesSelected(IReadOnlyList<IBrowserFile> files)
    {
        if (files == null || files.Count == 0) return;
        var zipFiles = files.Where(f => f.Name.EndsWith(".zip", StringComparison.OrdinalIgnoreCase)).ToList();
        if (zipFiles.Count == 0) { Snackbar.Add("Select .zip files.", Severity.Warning); return; }
        _uploading = true;
        _lastDetectedType = "";
        string? typeOverride = _uploadType == "Auto" ? null : _uploadType;
        var total = zipFiles.Count;
        var done = 0;
        var failed = 0;
        try
        {
            for (var i = 0; i < zipFiles.Count; i++)
            {
                var file = zipFiles[i];
                _uploadProgress = total > 1 ? $"Uploading {i + 1}/{total}..." : "Uploading...";
                StateHasChanged();
                try
                {
                    await using var stream = file.OpenReadStream(maxAllowedSize: 2L * 1024 * 1024 * 1024);
                    var pkg = await PkgService.UploadAsync(file.Name, stream, typeOverride, devOpsTaskUrl: null);
                    if (_uploadType == "Auto" && string.IsNullOrEmpty(_lastDetectedType))
                        _lastDetectedType = pkg.PackageType;
                    done++;
                }
                catch (Exception ex)
                {
                    failed++;
                    Snackbar.Add($"'{file.Name}': {ex.Message}", Severity.Error);
                }
            }
            if (done > 0)
            {
                Snackbar.Add(done == 1 ? $"Uploaded 1 package." : $"Uploaded {done} package(s).", Severity.Success);
                await LoadData();
            }
        }
        finally
        {
            _uploading = false;
            _uploadProgress = "";
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void SetDropZoneActive(bool active) { _dropZoneActive = active; StateHasChanged(); }

    [JSInvokable]
    public object GetUploadOptions() => new { packageType = _uploadType ?? "Auto" };

    private async Task LoadArchivedData()
    {
        _loadingArchive = true;
        _archivedPackages = await PkgService.GetArchivedAsync();
        _loadingArchive = false;
    }

    [JSInvokable]
    public async Task OnDropZoneUploadComplete(int successCount, int failCount)
    {
        if (successCount > 0)
        {
            Snackbar.Add(successCount == 1 ? "1 package uploaded." : $"{successCount} packages uploaded.", Severity.Success);
            await LoadData();
        }
        if (failCount > 0)
            Snackbar.Add($"{failCount} upload(s) failed.", Severity.Error);
        StateHasChanged();
    }

    // ===== Merge =====
    private void MergeSelected()
    {
        _mergePackages = _selectedForMerge.OrderBy(p => p.UploadedAt).ToList();
        _mergeStrategy = MergeService.DetectMergeStrategy(_mergePackages);
        _mergeConflicts = MergeService.GetMergeConflicts(_mergePackages);
        _mergeConflictActionForAll = -1;
        _mergeName = $"Merged_{string.Join("_", _mergePackages.Select(p => p.Name.Replace(" ", "")))}";
        if (_mergeName.Length > 100)
            _mergeName = $"Merged_{DateTime.UtcNow:yyyyMMdd_HHmmss}";
        _mergeDialogVisible = true;
    }

    private async Task ConfirmMerge()
    {
        if (string.IsNullOrWhiteSpace(_mergeName)) return;
        List<LcsModelConflictResolution>? resolutions = null;
        if (_mergeConflicts.Count > 0 && _mergeConflictActionForAll >= 0)
        {
            resolutions = _mergeConflicts
                .Select(c => new LcsModelConflictResolution { ModuleName = c.ModuleName, KeepPackageIndex = _mergeConflictActionForAll })
                .ToList();
        }
        _merging = true;
        StateHasChanged();
        try
        {
            await MergeSvc.MergePackagesAsync(_mergePackages, _mergeName.Trim(), null, resolutions);
            Snackbar.Add("Packages merged successfully!", Severity.Success);
            _mergeDialogVisible = false;
            await LoadData();
        }
        catch (Exception ex) { Snackbar.Add($"Merge failed: {ex.Message}", Severity.Error); }
        finally { _merging = false; }
    }

    // ===== Download =====
    private async Task DownloadPackage(Package pkg)
    {
        var url = $"/api/packages/{pkg.Id}/download";
        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    // ===== Convert to Unified =====
    private async Task ConvertToUnified(Package pkg)
    {
        if (_converting.Contains(pkg.Id)) return;
        _converting.Add(pkg.Id);
        StateHasChanged();
        try
        {
            Snackbar.Add($"Converting '{pkg.Name}' to Unified...", Severity.Info);
            var result = await PkgService.ConvertToUnifiedAsync(pkg, msg => _logger_ConvertLog(msg));
            Snackbar.Add($"Converted: '{result.Name}' ({FormatSize(result.FileSizeBytes)})", Severity.Success);
            await LoadData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Conversion failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _converting.Remove(pkg.Id);
            StateHasChanged();
        }
    }

    private async Task ConvertToLcs(Package pkg)
    {
        if (_converting.Contains(pkg.Id)) return;
        _converting.Add(pkg.Id);
        StateHasChanged();
        try
        {
            Snackbar.Add($"Converting '{pkg.Name}' to LCS...", Severity.Info);
            var result = await PkgService.ConvertToLcsAsync(pkg, msg => _logger_ConvertLog(msg));
            Snackbar.Add($"Converted: '{result.Name}' ({FormatSize(result.FileSizeBytes)})", Severity.Success);
            await LoadData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Conversion failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _converting.Remove(pkg.Id);
            StateHasChanged();
        }
    }

    private async Task ConvertAndDownload(Package pkg, string targetFormat)
    {
        if (_converting.Contains(pkg.Id)) return;
        _converting.Add(pkg.Id);
        StateHasChanged();
        try
        {
            Snackbar.Add($"Converting '{pkg.Name}' to {targetFormat} for download...", Severity.Info);

            Package result;
            if (targetFormat == "LCS")
                result = await PkgService.ConvertToLcsAsync(pkg, msg => _logger_ConvertLog(msg));
            else
                result = await PkgService.ConvertToUnifiedAsync(pkg, msg => _logger_ConvertLog(msg));

            Snackbar.Add($"Converted: '{result.Name}'. Starting download...", Severity.Success);
            await LoadData();
            var url = $"/api/packages/{result.Id}/download";
            await JS.InvokeVoidAsync("open", url, "_blank");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Conversion failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _converting.Remove(pkg.Id);
            StateHasChanged();
        }
    }

    private void _logger_ConvertLog(string msg)
    {
        // Log conversion progress to console (Serilog picks it up)
        Console.WriteLine(msg);
    }

    // ===== Edit Package =====
    private bool _editPackageDialogVisible;
    private string _editPackageName = "";
    private string _editPackageUrl = "";
    private int _editPackageId;

    private void OpenEditPackage(Package pkg)
    {
        _editPackageId = pkg.Id;
        _editPackageName = pkg.Name ?? "";
        _editPackageUrl = pkg.DevOpsTaskUrl ?? "";
        _editPackageDialogVisible = true;
    }

    private async Task SaveEditPackage()
    {
        if (string.IsNullOrWhiteSpace(_editPackageName)) return;
        await PkgService.UpdatePackageAsync(_editPackageId, _editPackageName.Trim(), _editPackageUrl);
        _editPackageDialogVisible = false;
        Snackbar.Add("Package updated.", Severity.Success);
        await LoadData();
        if (_packagesTabIndex == 1) await LoadArchivedData();
    }

    // ===== Archive / Restore =====
    private async Task ArchivePackage(Package pkg)
    {
        var ok = await DialogService.ShowMessageBox("Archive package", $"Archive '{pkg.Name}'? It will move to the Archive tab.", yesText: "Archive", cancelText: "Cancel");
        if (ok != true) return;
        await PkgService.ArchiveAsync(pkg.Id);
        Snackbar.Add($"'{pkg.Name}' archived.", Severity.Success);
        await LoadData();
        await LoadArchivedData();
    }

    private async Task RestorePackage(Package pkg)
    {
        await PkgService.RestoreAsync(pkg.Id);
        Snackbar.Add($"'{pkg.Name}' restored to active.", Severity.Success);
        _packagesTabIndex = 0;
        await LoadData();
        await LoadArchivedData();
    }

    private async Task DeletePackagePermanently(Package pkg)
    {
        var ok = await DialogService.ShowMessageBox("Delete permanently", $"Permanently delete '{pkg.Name}'? This cannot be undone.", yesText: "Delete", cancelText: "Cancel");
        if (ok != true) return;
        try
        {
            await PkgService.DeleteAsync(pkg.Id);
            Snackbar.Add("Package deleted.", Severity.Success);
            await LoadArchivedData();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    // ===== License Files =====
    private static bool HasLicenseFiles(Package pkg) =>
        !string.IsNullOrEmpty(pkg.LicenseFileNames);

    private static string GetLicenseTooltip(Package pkg)
    {
        if (string.IsNullOrEmpty(pkg.LicenseFileNames)) return "";
        try
        {
            var names = System.Text.Json.JsonSerializer.Deserialize<List<string>>(pkg.LicenseFileNames);
            if (names == null || names.Count == 0) return "";
            return $"License files: {string.Join(", ", names)}";
        }
        catch { return "Has license files"; }
    }

    private static List<string> GetLicenseFileNames(Package pkg)
    {
        if (string.IsNullOrEmpty(pkg.LicenseFileNames)) return new();
        try
        {
            return System.Text.Json.JsonSerializer.Deserialize<List<string>>(pkg.LicenseFileNames) ?? new();
        }
        catch { return new(); }
    }

    private async Task OpenLicenseUpload(Package pkg)
    {
        _licUploadTargetPkgId = pkg.Id;
        if (_licFileUpload != null)
            await _licFileUpload.OpenFilePickerAsync();
    }

    private async Task OnLicenseFilesSelected(IReadOnlyList<IBrowserFile> files)
    {
        if (files == null || files.Count == 0 || !_licUploadTargetPkgId.HasValue) return;
        var pkgId = _licUploadTargetPkgId.Value;
        _licUploadTargetPkgId = null;

        try
        {
            var licenseFiles = new List<(string FileName, byte[] Content)>();
            foreach (var file in files)
            {
                using var ms = new MemoryStream();
                using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                await stream.CopyToAsync(ms);
                licenseFiles.Add((file.Name, ms.ToArray()));
            }

            await PkgService.InjectLicenseFilesAsync(pkgId, licenseFiles);
            Snackbar.Add($"{licenseFiles.Count} license file(s) uploaded.", Severity.Success);
            await LoadData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"License upload failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task DownloadLicenses(Package pkg)
    {
        var url = $"/api/packages/{pkg.Id}/licenses";
        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    private async Task RefreshLicenseInfo(Package pkg)
    {
        try
        {
            var count = await PkgService.RefreshLicenseInfoAsync(pkg.Id);
            await LoadData();
            StateHasChanged();
            Snackbar.Add(count > 0
                ? $"License info updated: {count} file(s) found."
                : "License info updated. No license files found in package.",
                count > 0 ? Severity.Success : Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Refresh failed: {ex.Message}", Severity.Error);
        }
    }

    // ===== Delete =====
    private async Task ConfirmDeleteSelected()
    {
        if (_selectedForMerge.Count == 0) return;
        var result = await DialogService.ShowMessageBox("Delete packages",
            $"Delete {_selectedForMerge.Count} selected package(s)? This cannot be undone.", yesText: "Delete", cancelText: "Cancel");
        if (result != true) return;
        _deleting = true;
        StateHasChanged();
        try
        {
            var ids = _selectedForMerge.Select(p => p.Id).ToList();
            foreach (var id in ids)
            {
                try { await PkgService.DeleteAsync(id); } catch { /* skip if already gone */ }
            }
            Snackbar.Add($"{ids.Count} package(s) deleted.", Severity.Info);
            _selectedForMerge.Clear();
            await LoadData();
        }
        finally { _deleting = false; }
    }

    private async Task DeletePackage(Package pkg)
    {
        // First, check if package is used in deployments
        var (deploymentsCount, envNames) = await PkgService.GetPackageUsageAsync(pkg.Id);

        if (deploymentsCount > 0)
        {
            // Show informative message about package usage
            var envList = string.Join(", ", envNames.Take(5));
            if (envNames.Count > 5)
                envList += $" and {envNames.Count - 5} more";

            var message = deploymentsCount == 1
                ? $"This package is used in 1 deployment (environment: {envList}).\n\n" +
                  "You must delete the deployment before you can delete this package."
                : $"This package is used in {deploymentsCount} deployments across these environments:\n{envList}\n\n" +
                  "You must delete all related deployments before you can delete this package.";

            await DialogService.ShowMessageBox(
                "Cannot Delete Package",
                message,
                yesText: "OK");
            return;
        }

        // Package is not used, confirm deletion
        var result = await DialogService.ShowMessageBox(
            "Delete Package",
            $"Are you sure you want to delete '{pkg.Name}'?\n\nThis action cannot be undone.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                await PkgService.DeleteAsync(pkg.Id);
                Snackbar.Add("Package deleted successfully.", Severity.Success);
                await LoadData();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Failed to delete package: {ex.Message}", Severity.Error);
            }
        }
    }

    // ===== Helpers =====
    private static Color PkgTypeColor(string type)
    {
        if (type == "Merged") return Color.Secondary;
        if (type == "Unified") return Color.Success;
        if (type == "Other") return Color.Warning;
        return Color.Default; // LCS
    }

    private static string FormatSize(long b)
    {
        if (b < 1024) return $"{b} B";
        if (b < 1024 * 1024) return $"{b / 1024.0:F1} KB";
        if (b < 1024L * 1024 * 1024) return $"{b / 1024.0 / 1024.0:F1} MB";
        return $"{b / 1024.0 / 1024.0 / 1024.0:F2} GB";
    }
}
